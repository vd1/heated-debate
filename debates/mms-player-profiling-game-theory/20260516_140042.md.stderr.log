  }}
  tr:last-child th, tr:last-child td {{ border-bottom: 0; }}
  th {{
    width: 42%;
    font-weight: 560;
    color: #374151;
  }}
  td {{
    font-variant-numeric: tabular-nums;
    font-weight: 610;
  }}
  .note {{
    width: 34%;
    color: var(--muted);
    font-weight: 400;
    font-size: 13px;
  }}
  .chart {{
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }}
  .chart img {{
    display: block;
