    display: grid;
    grid-template-columns: repeat(6, minmax(120px, 1fr));
    gap: 12px;
  }}
  .stat {{
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    padding: 14px 16px;
  }}
  .stat span {{
    display: block;
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .04em;
  }}
  .stat strong {{
    display: block;
    margin-top: 6px;
    font-size: 20px;
    font-weight: 620;
  }}
  .frame {{
    flex: 1;
    min-height: 0;
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    overflow: hidden;
  }}
  .scatter-frame {{
    width: 100%;
