  .stat{display:flex;flex-direction:column;gap:1px}
  .stat-label{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--meta);font-weight:500}
  .stat-value{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:500;color:var(--fg2)}
  .stat-value a{color:var(--link);text-decoration:none;border-bottom:1px dashed var(--tick)}
  .stat-value a:hover{color:var(--link-hover);border-color:var(--link-hover)}
  .theme-btn{
    width:36px;height:36px;border-radius:50%;border:1px solid var(--pill-border);
    background:var(--pill-bg);cursor:pointer;font-size:16px;
    display:flex;align-items:center;justify-content:center;
    transition:all .2s;color:var(--meta);margin-top:2px;
  }
  .theme-btn:hover{border-color:var(--pill-hover);background:var(--surface)}

  /* toolbar */
  .toolbar{display:flex;gap:4px;margin-bottom:1.2em}
  .pill{
    padding:6px 16px;font-size:12px;font-weight:500;letter-spacing:.01em;
    cursor:pointer;border:1px solid var(--pill-border);border-radius:20px;
    background:var(--pill-bg);color:var(--pill-fg);transition:all .15s;
    font-family:'Inter',system-ui,sans-serif;
  }
  .pill:hover{border-color:var(--pill-hover);color:var(--fg2)}
  .pill.active{background:var(--pill-active-bg);color:var(--pill-active-fg);border-color:var(--pill-active-border)}

  /* chart */
  .chart-wrap{
    background:var(--svg-bg);border:1px solid var(--svg-border);
    border-radius:12px;box-shadow:var(--svg-shadow);
    padding:8px;transition:all .25s;display:inline-block;
  }
  svg{display:block}
</style>
</head><body>

<div class="header">
  <div class="header-left">
    <h1><span class="pair">${pair}</span><span class="subtitle">Borrower Positions</span></h1>
    <div class="stats">
      <div class="stat"><span class="stat-label">Morpho Market</span><span class="stat-value"><a href="${morphoUrl}" target="_blank">${shortId}</a></span></div>
      <div class="stat"><span class="stat-label">Positions</span><span class="stat-value">${pts.length}</span></div>
      <div class="stat"><span class="stat-label">LLTV</span><span class="stat-value">${(info.lltv * 100).toFixed(1)}%</span></div>
      <div class="stat"><span class="stat-label">Mmax</span><span class="stat-value">${Mmax.toFixed(2)}</span></div>
      <div class="stat"><span class="stat-label">Collateral APY</span><span class="stat-value">${(info.collateralApy * 100).toFixed(2)}%</span></div>
      <div class="stat"><span class="stat-label">Borrow APY</span><span class="stat-value">${(info.borrowApy * 100).toFixed(2)}%</span></div>
      <div class="stat"><span class="stat-label">Carry</span><span class="stat-value">${(info.carry * 100).toFixed(2)}%</span></div>
      <div class="stat"><span class="stat-label">&phi;max</span><span class="stat-value">${(info.phiMax * 100).toFixed(1)}%</span></div>
      <div class="stat"><span class="stat-label">Return range</span><span class="stat-value">${(phiMin * 100).toFixed(1)}% — ${(phiMax * 100).toFixed(1)}%</span></div>
      <div class="stat"><span class="stat-label">Equity-wtd &phi;</span><span class="stat-value">${(ewPhi * 100).toFixed(2)}%</span></div>
      <div class="stat"><span class="stat-label">Equity-wtd &sigma;(&phi;)</span><span class="stat-value">${(ewStd * 100).toFixed(2)}%</span></div>
    </div>
  </div>
  <button class="theme-btn" id="btn-theme" onclick="toggleTheme()">&#9790;</button>
</div>

<div class="toolbar">
  <button class="pill active" id="btn-log" onclick="setScale('log')">Log scale</button>
  <button class="pill" id="btn-linear" onclick="setScale('linear')">Linear</button>
  <button class="pill" id="btn-filter" onclick="toggleFilter()">Hide &lt; $1k</button>
</div>

<div class="chart-wrap">
  <svg id="chart" width="${W}" height="${H}"></svg>
</div>
<script>
const pts = ${data};
const W = ${W}, H = ${H}, pad = ${pad}, padR = ${padRight};
const Mmax = ${Mmax};
let mode = 'log';
let filterSmall = false;

function fmt(v) {
  if (v >= 1e6) return (v/1e6).toFixed(1)+'M';
  if (v >= 1000) return (v/1000).toFixed(0)+'k';
  return v.toFixed(0);
}

function phiColor(phi) {
  // red (negative) → yellow (0) → green (high positive)
  const pMin = Math.min(...pts.map(p=>p.phi));
  const pMax = Math.max(...pts.map(p=>p.phi));
  if (pMax === pMin) return 'hsl(210,60%,55%)';
  const t = (phi - pMin) / (pMax - pMin); // 0..1
  // hue: 220 (blue) → 0 (red)
  const hue = (1 - t) * 220;
  const light = 50 + t * 5;
  return 'hsl('+hue+',80%,'+light+'%)';
}

function draw() {
  const svg = document.getElementById('chart');
  const visible = filterSmall ? pts.filter(p => p.e >= 1000) : pts;
  if (visible.length === 0) {
    svg.innerHTML = '<text x="'+(W/2)+'" y="'+(H/2)+'" text-anchor="middle" font-size="14" fill="#9ca3af" font-family="Inter,system-ui,sans-serif">No positions match the current filter</text>';
    return;
  }
  const eMin = Math.min(...visible.map(p=>p.e));
  const eMax = Math.max(...visible.map(p=>p.e));
  const dataMmax = Math.max(...visible.map(p=>p.M));
  const yMax = Math.max(dataMmax, Mmax) * 1.08;

  let sx;
  if (mode === 'log') {
    const logMin = Math.log10(Math.max(eMin, 1));
    const logMax = Math.log10(eMax);
    sx = e => pad + (W - pad - padR) * (Math.log10(Math.max(e,1)) - logMin) / (logMax - logMin);
  } else {
    sx = e => pad + (W - pad - padR) * e / eMax;
  }
  const sy = m => H - pad - (H - 2*pad) * m / yMax;

  let html = '';

  const cs = getComputedStyle(document.documentElement);
  const cGrid = cs.getPropertyValue('--grid').trim();
  const cAxis = cs.getPropertyValue('--axis').trim();
  const cTick = cs.getPropertyValue('--tick').trim();
  const cTickLabel = cs.getPropertyValue('--tick-label').trim();
  const cLabel = cs.getPropertyValue('--label').trim();
  const cDot = cs.getPropertyValue('--dot').trim();
  const cDotStroke = cs.getPropertyValue('--dot-stroke').trim();
  const cDotOpacity = cs.getPropertyValue('--dot-opacity').trim();

  // grid lines
  for (let i = 1; i <= 6; i++) {
    const v = yMax * i / 6;
    const y = sy(v);
    html += '<line x1="'+pad+'" y1="'+y+'" x2="'+(W-padR)+'" y2="'+y+'" stroke="'+cGrid+'" stroke-width="1"/>';
  }
  if (mode === 'log') {
    const logMin = Math.log10(Math.max(eMin, 1));
    const logMax = Math.log10(eMax);
    for (let p10 = Math.ceil(logMin); p10 <= Math.floor(logMax); p10++) {
      const x = sx(Math.pow(10, p10));
      html += '<line x1="'+x+'" y1="'+pad+'" x2="'+x+'" y2="'+(H-pad)+'" stroke="'+cGrid+'" stroke-width="1"/>';
    }
  } else {
    for (let i = 1; i <= 6; i++) {
      const x = sx(eMax * i / 6);
      html += '<line x1="'+x+'" y1="'+pad+'" x2="'+x+'" y2="'+(H-pad)+'" stroke="'+cGrid+'" stroke-width="1"/>';
    }
  }

  // axes
  html += '<line x1="'+pad+'" y1="'+(H-pad)+'" x2="'+(W-padR)+'" y2="'+(H-pad)+'" stroke="'+cAxis+'" stroke-width="1"/>';
  html += '<line x1="'+pad+'" y1="'+pad+'" x2="'+pad+'" y2="'+(H-pad)+'" stroke="'+cAxis+'" stroke-width="1"/>';

  // Mmax horizontal line
  const yMmax = sy(Mmax);
  html += '<line x1="'+pad+'" y1="'+yMmax+'" x2="'+(W-padR)+'" y2="'+yMmax+'" stroke="#dc2626" stroke-width="1.5" stroke-dasharray="2,4" opacity="0.7"/>';
  html += '<line x1="'+(pad-5)+'" y1="'+yMmax+'" x2="'+pad+'" y2="'+yMmax+'" stroke="#dc2626"/>';
  html += '<text x="'+(pad-10)+'" y="'+(yMmax-2)+'" text-anchor="end" font-size="12" font-weight="500" fill="#dc2626" font-family="SF Mono,Menlo,monospace">M<tspan font-size="9" dy="3">max</tspan></text>';
  html += '<text x="'+(pad-10)+'" y="'+(yMmax+14)+'" text-anchor="end" font-size="11" fill="#dc2626" font-family="SF Mono,Menlo,monospace">'+Mmax.toFixed(2)+'</text>';

  // x ticks
  if (mode === 'log') {
    const logMin = Math.log10(Math.max(eMin, 1));
    const logMax = Math.log10(eMax);
    for (let p10 = Math.ceil(logMin); p10 <= Math.floor(logMax); p10++) {
      const v = Math.pow(10, p10);
      const x = sx(v);
      html += '<line x1="'+x+'" y1="'+(H-pad)+'" x2="'+x+'" y2="'+(H-pad+5)+'" stroke="'+cTick+'"/>';
      html += '<text x="'+x+'" y="'+(H-pad+22)+'" text-anchor="middle" font-size="12" fill="'+cTickLabel+'" font-family="SF Mono,Menlo,monospace">'+fmt(v)+'</text>';
    }
  } else {
    for (let i = 0; i <= 6; i++) {
      const v = eMax * i / 6;
      const x = sx(v);
      html += '<line x1="'+x+'" y1="'+(H-pad)+'" x2="'+x+'" y2="'+(H-pad+5)+'" stroke="'+cTick+'"/>';
      html += '<text x="'+x+'" y="'+(H-pad+22)+'" text-anchor="middle" font-size="12" fill="'+cTickLabel+'" font-family="SF Mono,Menlo,monospace">'+fmt(v)+'</text>';
    }
  }

  // y ticks
  for (let i = 0; i <= 6; i++) {
    const v = yMax * i / 6;
    const y = sy(v);
    html += '<line x1="'+(pad-5)+'" y1="'+y+'" x2="'+pad+'" y2="'+y+'" stroke="'+cTick+'"/>';
    html += '<text x="'+(pad-10)+'" y="'+(y+4)+'" text-anchor="end" font-size="12" fill="'+cTickLabel+'" font-family="SF Mono,Menlo,monospace">'+v.toFixed(1)+'</text>';
  }

  // axis labels
  html += '<text x="'+((pad+W-padR)/2)+'" y="'+(H-18)+'" text-anchor="middle" font-size="13" font-weight="500" fill="'+cLabel+'">Equity (USDC)'+(mode==='log'?' [log scale]':'')+'</text>';
  html += '<text x="20" y="'+(H/2)+'" text-anchor="middle" font-size="13" font-weight="500" fill="'+cLabel+'" transform="rotate(-90 20 '+(H/2)+')">Multiplier (debt / equity)</text>';

  // points
  for (const p of visible) {
    const cx = sx(p.e), cy = sy(p.M);
    if (cx >= pad && cx <= W-padR)
      html += '<circle cx="'+cx+'" cy="'+cy+'" r="5" fill="'+phiColor(p.phi)+'" opacity="0.75" stroke="'+phiColor(p.phi)+'" stroke-width="0.5" stroke-opacity="0.3"><title>equity = $'+p.e.toLocaleString(undefined,{maximumFractionDigits:0})+' \\u2014 multiplier = '+p.M.toFixed(2)+'x \\u2014 \\u03C6 = '+(p.phi*100).toFixed(1)+'%</title></circle>';
  }

  // color legend
  const lgX = W - padR + 15, lgY = pad + 20, lgH = 120, lgW = 12;
  const pMin = Math.min(...visible.map(p=>p.phi));
  const pMax = Math.max(...visible.map(p=>p.phi));
  html += '<defs><linearGradient id="phiGrad" x1="0" y1="1" x2="0" y2="0">';
  for (let i = 0; i <= 10; i++) {
    const t = i / 10;
    html += '<stop offset="'+(t*100)+'%" stop-color="hsl('+((1-t)*220)+',80%,'+(50+t*5)+'%)"/>';
  }
  html += '</linearGradient></defs>';
  html += '<rect x="'+lgX+'" y="'+lgY+'" width="'+lgW+'" height="'+lgH+'" rx="2" fill="url(#phiGrad)"/>';
  html += '<text x="'+(lgX+lgW+5)+'" y="'+(lgY+5)+'" font-size="10" fill="'+cTickLabel+'" font-family="SF Mono,Menlo,monospace">'+(pMax*100).toFixed(1)+'%</text>';
  html += '<text x="'+(lgX+lgW+5)+'" y="'+(lgY+lgH)+'" font-size="10" fill="'+cTickLabel+'" font-family="SF Mono,Menlo,monospace">'+(pMin*100).toFixed(1)+'%</text>';
  html += '<text x="'+(lgX+lgW/2)+'" y="'+(lgY-6)+'" text-anchor="middle" font-size="10" font-weight="500" fill="'+cLabel+'">\\u03C6</text>';

  svg.innerHTML = html;
}

function setScale(s) {
  mode = s;
  document.getElementById('btn-linear').className = s==='linear'?'pill active':'pill';
  document.getElementById('btn-log').className = s==='log'?'pill active':'pill';
  draw();
}

function toggleFilter() {
  filterSmall = !filterSmall;
  document.getElementById('btn-filter').className = filterSmall ? 'pill active' : 'pill';
  draw();
}

function toggleTheme() {
  document.documentElement.classList.toggle('dark');
  const isDark = document.documentElement.classList.contains('dark');
  document.getElementById('btn-theme').innerHTML = isDark ? '&#9788;' : '&#9790;';
  draw();
}

draw();
</script>
</body></html>`;
}

// ---------- main ----------

async function main() {
  console.log(`Market: ${MARKET_ID}`);
  console.log("Fetching market info and borrowing positions…");
  const [info, raw] = await Promise.all([fetchMarketInfo(), fetchAllPositions()]);
  const Mmax = info.lltv / (1 - info.lltv);
  console.log(`${info.collateral}/${info.loan} — LLTV: ${(info.lltv * 100).toFixed(1)}% → Mmax: ${Mmax.toFixed(2)}`);
  console.log(`Total raw positions: ${raw.length}`);

  console.log(`Collateral APY: ${(info.collateralApy * 100).toFixed(2)}% | Borrow APY: ${(info.borrowApy * 100).toFixed(2)}%`);
  const pts = toEquityMultiplier(raw, info);
  console.log(`Positive (e, M) points: ${pts.length}`);

  if (pts.length === 0) {
    console.log("No plottable points — check API fields.");
    if (raw.length > 0) console.log("Sample:", JSON.stringify(raw[0], null, 2));
    return;
  }

  const now = new Date();
  const ts = now.toISOString().slice(0, 16).replace("T", "_").replace(":", "");
  const tag = MARKET_ID.slice(2, 10);
  const outDir = import.meta.dir + "/scatter";
  await mkdir(outDir, { recursive: true });
  const outPath = `${outDir}/scatter_eM_${tag}_${ts}.html`;
  await Bun.write(outPath, generateHTML(pts, info));
  console.log(`Plot written to ${outPath}`);

  Bun.spawn(["open", outPath]);
}

main();


--- ../mms/morpho_tranche_spread.py ---
#!/usr/bin/env python3
"""Compute wash-lending attachment points and implied spreads for Morpho markets.

The script ingests the watcher export (morpho_edges.csv) produced by
KilDef/scripts/build_morpho_graph.py.

NOTE: The CSV only has aggregate pool data, not per-borrower positions.
As a proxy we use M_max = LLTV / (1 - LLTV), the worst-case leverage
assuming every borrower maxes out their LLTV.  This gives a *lower bound*
on the attachment point (worst case for senior).  For true M_i distributions,
query the Morpho Blue subgraph for per-position collateral/debt.

Attachment point formula (from washLending.tex, homogeneous case):
  delta_A = 1 - M * LLTV / (1 + M)

For each target market we then estimate:
  * breach probability over the chosen horizon given a volatility guess
  * the "fair" senior spread implied by that tail probability
  * the observed borrow rate (approximated as supplyAPY / util when direct
    borrow quotes are unavailable in the watcher export)

Outputs a CSV plus a human-readable table so the results can feed the
wash-lending tranche write-up.
"""

from __future__ import annotations

import argparse
import csv
import json
import math
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


REPO_ROOT = Path(__file__).resolve().parent
WORKTREE_ROOT = REPO_ROOT
DEFAULT_EDGES = WORKTREE_ROOT / "output/morpho_graph/morpho_edges.csv"
DEFAULT_MARKETS = WORKTREE_ROOT.parents[0] / "KilDef" / "discovery" / "morpho" / "morpho_markets_all.csv"


@dataclass
class MarketTarget:
    loan: str
    collat: str
    chain_id: int = 1
    sigma: float = 0.80  # annualized vol assumption
    horizon_days: float = 7.0
    lgd: float = 1.0     # loss-given-default assumption
    nickname: Optional[str] = None

    def label(self) -> str:
        base = f"{self.loan}/{self.collat} @ chain {self.chain_id}"
        return f"{self.nickname} ({base})" if self.nickname else base


def parse_float(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def load_edges(path: Path) -> List[Dict[str, Any]]:
    if not path.exists():
        raise FileNotFoundError(f"edges CSV not found: {path}")
    with path.open("r", encoding="utf-8") as fh:
        reader = csv.DictReader(fh)
        return list(reader)


def load_market_meta(path: Path) -> Dict[str, Dict[str, Any]]:
    if not path or not path.exists():
        return {}
    with path.open("r", encoding="utf-8") as fh:
        reader = csv.DictReader(fh)
        return {row.get("uniqueKey", ""): row for row in reader if row.get("uniqueKey")}


def find_row(edges: List[Dict[str, Any]], target: MarketTarget) -> Dict[str, Any]:
    matches = [
        row for row in edges
        if (row.get("loan_symbol") or "").upper() == target.loan.upper()
        and (row.get("collat_symbol") or "").upper() == target.collat.upper()
        and int(parse_float(row.get("chainId"), default=0)) == target.chain_id
    ]
    if not matches:
        available = sorted({(row.get("loan_symbol"), row.get("collat_symbol")) for row in edges})
        raise ValueError(f"No market found for {target.label()}. "
                         f"Available sample: {available[:5]}")
    if len(matches) > 1:
        # If multiple markets (e.g. different deployments) exist, pick the largest by borrow USD.
        matches.sort(key=lambda r: parse_float(r.get("borrowUSD"), default=0.0), reverse=True)
    return matches[0]


def normal_tail_probability(delta_a: float, sigma: float, horizon_days: float) -> float:
    """Approximate P(delta > delta_A) assuming N(0, sigma*sqrt(t))."""
    if sigma <= 0 or horizon_days <= 0:
        return 0.0
    scale = sigma * math.sqrt(horizon_days / 365.0)
    if scale <= 0:
        return 0.0
    z = delta_a / scale
    # tail probability = 0.5 * erfc(z / sqrt(2))
    return 0.5 * math.erfc(z / math.sqrt(2.0))


def fair_spread(prob: float, lgd: float, horizon_days: float) -> float:
    """Return annualized fair spread (as fraction) given tail probability and LGD."""
    tau_years = horizon_days / 365.0
    if prob <= 0 or lgd <= 0 or tau_years <= 0:
        return 0.0
    # Clamp to avoid log(<=0)
    loss_prob = min(max(prob * lgd, 1e-12), 1 - 1e-6)
    return -math.log(1 - loss_prob) / tau_years


def approx_borrow_rate(meta_row: Optional[Dict[str, Any]]) -> float:
    """Approximate borrow APY as supplyAPY / util (reserve factor ignored)."""
    if not meta_row:
        return float("nan")
    supply_apy = parse_float(meta_row.get("supplyAPY"))
    util = parse_float(meta_row.get("util"))
    if util <= 0:
        return float("nan")
    return supply_apy / util


def compute_metrics(
    row: Dict[str, Any],
    target: MarketTarget,
    meta_row: Optional[Dict[str, Any]],
) -> Dict[str, Any]:
    supply = parse_float(row.get("supplyUSD"))
    liquidity = parse_float(row.get("liquidityUSD"))
    borrow = parse_float(row.get("borrowUSD"))
    if borrow == 0.0 and liquidity and supply:
        borrow = max(supply - liquidity, 0.0)
    lltv_pct = parse_float(row.get("LLTV_pct"))
    lltv = lltv_pct / 100.0 if lltv_pct else 0.0
    util_pct = parse_float(row.get("util_pct"))
    util = util_pct / 100.0 if util_pct else 0.0

    # M_max = LLTV / (1 - LLTV): worst-case leverage if every borrower
    # maxes out their collateral ratio.  This is a lower bound on delta_A.
    m_mult = lltv / (1.0 - lltv) if lltv < 1.0 else float("inf")
    delta_a = float("nan")
    if lltv > 0 and math.isfinite(m_mult):
        # Correct attachment point formula: delta_A = 1 - M*ell/(1+M)
        delta_a = 1.0 - m_mult * lltv / (1.0 + m_mult)
    prob = normal_tail_probability(max(delta_a, 0.0), target.sigma, target.horizon_days)
    spread = fair_spread(prob, target.lgd, target.horizon_days)
    borrow_rate = approx_borrow_rate(meta_row)

    return {
        "loan": row.get("loan_symbol") or row.get("loan_addr"),
        "collat": row.get("collat_symbol") or row.get("collat_addr"),
        "uniqueKey": row.get("uniqueKey"),
        "supplyUSD": supply,
        "borrowUSD": borrow,
        "liquidityUSD": liquidity,
        "LLTV_pct": lltv_pct,
        "util_pct": util_pct,
        "M": m_mult,
        "delta_A": delta_a,
        "sigma": target.sigma,
        "horizon_days": target.horizon_days,
        "tail_prob": prob,
        "fair_spread": spread,
        "approx_borrow_rate": borrow_rate,
        "lgd": target.lgd,
        "label": target.label(),
    }


def write_csv(rows: List[Dict[str, Any]], path: Path) -> None:
    if not rows:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    fieldnames = [
        "label", "loan", "collat", "uniqueKey",
        "supplyUSD", "borrowUSD", "liquidityUSD",
        "LLTV_pct", "util_pct", "M", "delta_A",
        "sigma", "horizon_days", "tail_prob",
        "fair_spread", "approx_borrow_rate", "lgd",
    ]
    with path.open("w", encoding="utf-8", newline="") as fh:
        writer = csv.DictWriter(fh, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows({k: row.get(k) for k in fieldnames} for row in rows)


def format_row(row: Dict[str, Any]) -> str:
    def fmt_dollar(value: float) -> str:
        if math.isnan(value) or value is None:
            return "n/a"
        return f"${value:,.0f}"

    def fmt_pct(value: float) -> str:
        if value is None or math.isnan(value):
            return "n/a"
        return f"{100*value:.2f}%"

    return (
        f"{row['label']:<32} "
        f"M_max={row['M']:.2f}  "
        f"δ_A={fmt_pct(row['delta_A'])}  "
        f"supply={fmt_dollar(row['supplyUSD'])}  "
        f"borrow={fmt_dollar(row['borrowUSD'])}  "
        f"liq={fmt_dollar(row['liquidityUSD'])}  "
        f"tail={fmt_pct(row['tail_prob'])}  "
        f"fair={fmt_pct(row['fair_spread'])}  "
        f"obs≈{fmt_pct(row['approx_borrow_rate'])}"
    )


def build_targets(custom: Optional[str]) -> List[MarketTarget]:
    preset = [
        MarketTarget(loan="USDT", collat="sUSDS", sigma=0.05, horizon_days=7, nickname="USDT/sUSDS"),
        MarketTarget(loan="USDS", collat="wstETH", sigma=0.80, horizon_days=7, nickname="USDS/wstETH"),
        MarketTarget(loan="USDC", collat="wstETH", sigma=0.80, horizon_days=7, nickname="USDC/wstETH"),
        MarketTarget(loan="USDC", collat="cbETH", sigma=0.80, horizon_days=7, nickname="USDC/cbETH"),
        MarketTarget(loan="USDT", collat="USDS", sigma=0.05, horizon_days=7, nickname="USDT/USDS (LLTV 97%)"),
    ]
    if not custom:
        return preset
    parsed: List[MarketTarget] = []
    for item in custom.split(","):
        parts = item.strip().split("/")
        if len(parts) != 2:
            raise ValueError(f"Invalid market spec '{item}'. Use loan/collat format.")
        parsed.append(MarketTarget(loan=parts[0].strip(), collat=parts[1].strip()))
    return parsed


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--edges", type=Path, default=DEFAULT_EDGES,
                        help="Path to morpho_edges.csv (default: output/morpho_graph/morpho_edges.csv)")
    parser.add_argument("--markets", type=str, default=None,
                        help="Comma-separated loan/collat overrides (e.g. 'USDT/sUSDS,USDC/wstETH').")
    parser.add_argument("--markets-csv", type=Path, default=DEFAULT_MARKETS,
                        help="Optional morpho_markets_all.csv path for supplyAPY/util data.")
    parser.add_argument("--out", type=Path,
                        default=Path("output/morpho_tranche_report.csv"),
                        help="CSV output path (default: output/morpho_tranche_report.csv)")
    parser.add_argument("--json", type=Path,
                        default=Path("output/morpho_tranche_report.json"),
                        help="Optional JSON dump of the computed rows.")
    args = parser.parse_args()

    edges = load_edges(args.edges)
    meta = load_market_meta(args.markets_csv) if args.markets_csv else {}
    targets = build_targets(args.markets)
    results: List[Dict[str, Any]] = []
    missing: List[Tuple[MarketTarget, str]] = []
    for target in targets:
        try:
            row = find_row(edges, target)
        except ValueError as exc:
            missing.append((target, str(exc)))
            continue
        meta_row = meta.get(row.get("uniqueKey", ""))
        metrics = compute_metrics(row, target, meta_row)
        results.append(metrics)
        print(format_row(metrics))

    for target, msg in missing:
        print(f"[warn] {target.label()}: {msg}")

    write_csv(results, args.out)
    if args.json:
        args.json.parent.mkdir(parents=True, exist_ok=True)
        with args.json.open("w", encoding="utf-8") as fh:
            json.dump(results, fh, indent=2)
    if missing:
        print(f"[warn] missing {len(missing)} market(s); see warnings above.")
    return 0 if results else 1


if __name__ == "__main__":
    raise SystemExit(main())


