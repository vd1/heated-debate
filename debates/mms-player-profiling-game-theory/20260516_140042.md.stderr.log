  </section>
  <button class="nav nav-prev" type="button" aria-label="Previous slide">&#8249;</button>
  <button class="nav nav-next" type="button" aria-label="Next slide">&#8250;</button>
</main>
<script>
  function go(delta) {{
    const deck = document.getElementById('deck');
    deck.scrollBy({{ top: delta * window.innerHeight, behavior: 'smooth' }});
  }}
  document.querySelector('.nav-prev').addEventListener('click', () => go(-1));
  document.querySelector('.nav-next').addEventListener('click', () => go(1));
  document.addEventListener('keydown', event => {{
    if (event.key === 'ArrowRight' || event.key === 'PageDown' || event.key === ' ') {{
      go(1);
    }}
    if (event.key === 'ArrowLeft' || event.key === 'PageUp') {{
      go(-1);
    }}
  }});
</script>
