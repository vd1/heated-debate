    padding: 0;
    gap: 0;
  }}
  .title-slide {{
    justify-content: center;
    max-width: 1180px;
  }}
  h1, h2 {{
    margin: 0;
    letter-spacing: 0;
    line-height: 1.05;
  }}
  h1 {{ font-size: 64px; font-weight: 650; }}
  h2 {{ font-size: 34px; font-weight: 620; }}
  .subtitle {{
    font-size: 22px;
    color: var(--muted);
    margin-top: 8px;
  }}
  .meta {{
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--muted);
    font-size: 14px;
  }}
  .meta span {{
    border: 1px solid var(--line);
    background: var(--panel);
    padding: 8px 10px;
    border-radius: 6px;
  }}
  .stats {{
    display: grid;
    grid-template-columns: repeat(6, minmax(120px, 1fr));
    gap: 12px;
  }}
  .stat {{
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    padding: 14px 16px;
  }}
  .stat span {{
    display: block;
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .04em;
  }}
  .stat strong {{
    display: block;
    margin-top: 6px;
    font-size: 20px;
    font-weight: 620;
  }}
  .frame {{
    flex: 1;
    min-height: 0;
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    overflow: hidden;
  }}
  .scatter-frame {{
    width: 100%;
