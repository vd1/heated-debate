#!/usr/bin/env python3
"""Build a self-contained HTML slide deck from the latest Morpho outputs."""

from __future__ import annotations

import argparse
import base64
import html
import json
from datetime import datetime
from pathlib import Path
from typing import Any


DEFAULT_MARKET = "0x3274643db77a064abd3bc851de77556a4ad2e2f502f4f0c80845fa8f909ecf0b"
DEFAULT_OUTPUT_DIR = Path("output/morpho_positions")


def latest_scatter(scatter_dir: Path, market_key: str) -> Path:
    tag = market_key[2:10]
    matches = sorted(scatter_dir.glob(f"scatter_eM_{tag}_*.html"), key=lambda path: path.stat().st_mtime)
    if not matches:
        raise FileNotFoundError(f"No scatter HTML found for tag {tag} in {scatter_dir}")
    return matches[-1]


def read_summary(path: Path, market_key: str) -> dict[str, Any]:
    data = json.loads(path.read_text(encoding="utf-8"))
    for row in data:
        if row.get("market_key") == market_key:
            return row
    if data:
        return data[0]
    raise ValueError(f"No market summaries found in {path}")


def fmt_money(value: Any) -> str:
    try:
        return f"${float(value):,.0f}"
    except (TypeError, ValueError):
        return "n/a"


def fmt_number(value: Any, digits: int = 2) -> str:
    try:
        return f"{float(value):.{digits}f}"
    except (TypeError, ValueError):
        return "n/a"


def fmt_pct(value: Any, digits: int = 2) -> str:
    try:
        return f"{100 * float(value):.{digits}f}%"
    except (TypeError, ValueError):
        return "n/a"


def image_data_uri(path: Path) -> str:
    encoded = base64.b64encode(path.read_bytes()).decode("ascii")
    return f"data:image/png;base64,{encoded}"


def sanitize_scatter_html(scatter_html: str) -> str:
    """Remove optional external font links from embedded scatter HTML."""
    return "\n".join(
        line
        for line in scatter_html.splitlines()
        if "fonts.googleapis.com" not in line
    )


def stat_card(label: str, value: str) -> str:
    return f'<div class="stat"><span>{html.escape(label)}</span><strong>{html.escape(value)}</strong></div>'


def metric_row(label: str, value: str, note: str = "") -> str:
    note_html = f'<td class="note">{html.escape(note)}</td>' if note else '<td class="note"></td>'
    return f"<tr><th>{html.escape(label)}</th><td>{html.escape(value)}</td>{note_html}</tr>"


def build_deck(
    summary: dict[str, Any],
    scatter_html: str,
    scatter_path: Path,
    risk_chart_uri: str,
    generated_at: datetime,
) -> str:
    label = summary.get("label", "Morpho market")
    market_key = summary.get("market_key", DEFAULT_MARKET)
    supply_source = summary.get("supply_apy_source") or "n/a"
    timestamp = generated_at.strftime("%Y-%m-%d %H:%M:%S")
    scatter_srcdoc = html.escape(scatter_html, quote=True)

    top_stats = "\n".join([
        stat_card("Positions", fmt_number(summary.get("n_positions"), 0)),
        stat_card("Total Debt", fmt_money(summary.get("total_debt_usd"))),
        stat_card("Total Equity", fmt_money(summary.get("total_equity_usd"))),
        stat_card("Supply APY", f"{fmt_pct(summary.get('supply_apy'))} ({supply_source})"),
        stat_card("LLTV", fmt_pct(summary.get("LLTV"), 1)),
        stat_card("Mmax", fmt_number(summary.get("M_max_theoretical"))),
    ])

    metric_rows = "\n".join([
        metric_row("M aggregate", fmt_number(summary.get("M_aggregate")), "total debt / positive equity"),
        metric_row("M median", fmt_number(summary.get("M_median")), "unweighted position median"),
        metric_row("M p90", fmt_number(summary.get("M_p90")), "unweighted position percentile"),
        metric_row("M p50 equity-weighted", fmt_number(summary.get("M_p50_equity_weighted")), "weighted by positive equity"),
        metric_row("M p90 equity-weighted", fmt_number(summary.get("M_p90_equity_weighted")), "weighted by positive equity"),
        metric_row("M p50 debt-weighted", fmt_number(summary.get("M_p50_debt_weighted")), "weighted by borrowAssetsUsd"),
        metric_row("M p90 debt-weighted", fmt_number(summary.get("M_p90_debt_weighted")), "weighted by borrowAssetsUsd"),
        metric_row("M max observed", fmt_number(summary.get("M_max_observed")), "highest borrower leverage"),
        metric_row("delta_A aggregate", fmt_pct(summary.get("delta_A_aggregate")), "aggregate attachment point"),
        metric_row("delta_A worst case", fmt_pct(summary.get("delta_A_worst_case")), "Mmax bound"),
        metric_row("first liquidation", fmt_pct(summary.get("delta_first_liquidation")), "closest borrower threshold"),
    ])

    return f"""<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{html.escape(label)} Morpho Deck</title>
<style>
  :root {{
    --bg: #f6f7f9;
    --ink: #111827;
    --muted: #6b7280;
    --line: #d7dce3;
    --panel: #ffffff;
    --accent: #2563eb;
  }}
  * {{ box-sizing: border-box; }}
  body {{
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--ink);
  }}
  .deck {{
    height: 100vh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
  }}
  .slide {{
    min-height: 100vh;
    scroll-snap-align: start;
    padding: 40px 48px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }}
  .scatter-slide {{
    padding: 0;
    gap: 0;
  }}
  .title-slide {{
    justify-content: center;
    max-width: 1180px;
  }}
  h1, h2 {{
    margin: 0;
    letter-spacing: 0;
    line-height: 1.05;
  }}
  h1 {{ font-size: 64px; font-weight: 650; }}
  h2 {{ font-size: 34px; font-weight: 620; }}
  .subtitle {{
    font-size: 22px;
    color: var(--muted);
    margin-top: 8px;
  }}
  .meta {{
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--muted);
    font-size: 14px;
  }}
  .meta span {{
    border: 1px solid var(--line);
    background: var(--panel);
    padding: 8px 10px;
    border-radius: 6px;
  }}
  .stats {{
    display: grid;
    grid-template-columns: repeat(6, minmax(120px, 1fr));
    gap: 12px;
  }}
  .stat {{
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    padding: 14px 16px;
  }}
  .stat span {{
    display: block;
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .04em;
  }}
  .stat strong {{
    display: block;
    margin-top: 6px;
    font-size: 20px;
    font-weight: 620;
  }}
  .frame {{
    flex: 1;
    min-height: 0;
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    overflow: hidden;
  }}
  .scatter-frame {{
    width: 100%;
    height: 100vh;
    border: 0;
    border-radius: 0;
    position: relative;
    overflow: hidden;
  }}
  .scatter-frame iframe {{
    width: 111.111%;
    height: 111.111%;
    transform: scale(.9);
    transform-origin: 0 0;
  }}
  iframe {{
    width: 100%;
    height: 100%;
    border: 0;
    background: white;
  }}
  .two-col {{
    display: grid;
    grid-template-columns: minmax(420px, .85fr) minmax(480px, 1.15fr);
    gap: 22px;
    min-height: 0;
    flex: 1;
  }}
  table {{
    width: 100%;
    border-collapse: collapse;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    font-size: 15px;
  }}
  th, td {{
    border-bottom: 1px solid var(--line);
    padding: 12px 14px;
    text-align: left;
  }}
  tr:last-child th, tr:last-child td {{ border-bottom: 0; }}
  th {{
    width: 42%;
    font-weight: 560;
    color: #374151;
  }}
  td {{
    font-variant-numeric: tabular-nums;
    font-weight: 610;
  }}
  .note {{
    width: 34%;
    color: var(--muted);
    font-weight: 400;
    font-size: 13px;
  }}
  .chart {{
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }}
  .chart img {{
    display: block;
    max-width: 100%;
    max-height: calc(100vh - 180px);
    object-fit: contain;
  }}
  .footer {{
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--muted);
    font-size: 12px;
  }}
  code {{
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: #374151;
  }}
  .nav {{
    position: fixed;
    z-index: 20;
    top: 50%;
    transform: translateY(-50%);
    width: 42px;
    height: 64px;
    border: 1px solid rgba(17, 24, 39, .16);
    background: rgba(255, 255, 255, .88);
    color: #111827;
    border-radius: 8px;
    font-size: 34px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(17, 24, 39, .12);
  }}
  .nav:hover {{
    background: #ffffff;
    border-color: rgba(17, 24, 39, .28);
  }}
  .nav-prev {{ left: 14px; }}
  .nav-next {{ right: 14px; }}
  @media (max-width: 980px) {{
    .slide {{ padding: 24px; }}
    h1 {{ font-size: 42px; }}
    .stats {{ grid-template-columns: repeat(2, 1fr); }}
    .two-col {{ grid-template-columns: 1fr; }}
    .frame {{ min-height: 70vh; }}
  }}
</style>
</head>
<body>
<main class="deck" id="deck">
  <section class="slide title-slide">
    <h1>{html.escape(label)} borrower microstructure</h1>
    <p class="subtitle">Positions, leverage statistics, and lender risk/return snapshot.</p>
    <div class="meta">
      <span>Generated {html.escape(timestamp)}</span>
      <span>Market <code>{html.escape(str(market_key))}</code></span>
      <span>Scatter <code>{html.escape(str(scatter_path))}</code></span>
    </div>
    <div class="stats">{top_stats}</div>
  </section>

  <section class="slide scatter-slide">
    <div class="frame scatter-frame">
      <iframe title="Borrower scatter" srcdoc="{scatter_srcdoc}"></iframe>
    </div>
  </section>

  <section class="slide">
    <h2>M Statistics And Lender Risk/Return</h2>
    <div class="two-col">
      <table>
        <tbody>{metric_rows}</tbody>
      </table>
      <div class="chart">
        <img alt="Lender risk return chart" src="{risk_chart_uri}">
      </div>
    </div>
    <div class="footer"><span>Weighted percentiles use cumulative size weights over borrower M_i.</span><span>Slide 3</span></div>
  </section>
  <button class="nav nav-prev" type="button" aria-label="Previous slide">&#8249;</button>
  <button class="nav nav-next" type="button" aria-label="Next slide">&#8250;</button>
</main>
<script>
  function go(delta) {{
    const deck = document.getElementById('deck');
    deck.scrollBy({{ top: delta * window.innerHeight, behavior: 'smooth' }});
  }}
  document.querySelector('.nav-prev').addEventListener('click', () => go(-1));
  document.querySelector('.nav-next').addEventListener('click', () => go(1));
  document.addEventListener('keydown', event => {{
    if (event.key === 'ArrowRight' || event.key === 'PageDown' || event.key === ' ') {{
      go(1);
    }}
    if (event.key === 'ArrowLeft' || event.key === 'PageUp') {{
      go(-1);
    }}
  }});
</script>
</body>
</html>
"""


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--market", default=DEFAULT_MARKET)
    parser.add_argument("--scatter-dir", type=Path, default=Path("scatter"))
    parser.add_argument("--summary", type=Path, default=DEFAULT_OUTPUT_DIR / "aggregate_summary.json")
    parser.add_argument("--risk-chart", type=Path, default=DEFAULT_OUTPUT_DIR / "lender_risk_return.png")
    parser.add_argument("--out", type=Path, default=None)
    args = parser.parse_args()

    scatter_path = latest_scatter(args.scatter_dir, args.market)
    summary = read_summary(args.summary, args.market)
    scatter_html = sanitize_scatter_html(scatter_path.read_text(encoding="utf-8"))
    risk_chart_uri = image_data_uri(args.risk_chart)
    generated_at = datetime.now().astimezone()

    out_path = args.out or DEFAULT_OUTPUT_DIR / f"deck_{args.market[2:10]}_{generated_at.strftime('%Y-%m-%d_%H%M')}.html"
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(
        build_deck(summary, scatter_html, scatter_path, risk_chart_uri, generated_at),
        encoding="utf-8",
    )
    print(f"Deck written to {out_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())


