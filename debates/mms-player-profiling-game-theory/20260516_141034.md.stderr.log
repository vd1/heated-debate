  .nav-next {{ right: 14px; }}
  @media (max-width: 980px) {{
    .slide {{ padding: 24px; }}
    h1 {{ font-size: 42px; }}
    .stats {{ grid-template-columns: repeat(2, 1fr); }}
    .two-col {{ grid-template-columns: 1fr; }}
    .frame {{ min-height: 70vh; }}
  }}
</style>
</head>
<body>
<main class="deck" id="deck">
  <section class="slide title-slide">
    <h1>{html.escape(label)} borrower microstructure</h1>
    <p class="subtitle">Positions, leverage statistics, and lender risk/return snapshot.</p>
    <div class="meta">
      <span>Generated {html.escape(timestamp)}</span>
      <span>Market <code>{html.escape(str(market_key))}</code></span>
      <span>Scatter <code>{html.escape(str(scatter_path))}</code></span>
    </div>
    <div class="stats">{top_stats}</div>
  </section>

  <section class="slide scatter-slide">
    <div class="frame scatter-frame">
      <iframe title="Borrower scatter" srcdoc="{scatter_srcdoc}"></iframe>
    </div>
  </section>

  <section class="slide">
    <h2>M Statistics And Lender Risk/Return</h2>
    <div class="two-col">
      <table>
        <tbody>{metric_rows}</tbody>
      </table>
      <div class="chart">
        <img alt="Lender risk return chart" src="{risk_chart_uri}">
      </div>
    </div>
    <div class="footer"><span>Weighted percentiles use cumulative size weights over borrower M_i.</span><span>Slide 3</span></div>
  </section>
  <button class="nav nav-prev" type="button" aria-label="Previous slide">&#8249;</button>
  <button class="nav nav-next" type="button" aria-label="Next slide">&#8250;</button>
</main>
<script>
  function go(delta) {{
    const deck = document.getElementById('deck');
    deck.scrollBy({{ top: delta * window.innerHeight, behavior: 'smooth' }});
  }}
  document.querySelector('.nav-prev').addEventListener('click', () => go(-1));
  document.querySelector('.nav-next').addEventListener('click', () => go(1));
  document.addEventListener('keydown', event => {{
    if (event.key === 'ArrowRight' || event.key === 'PageDown' || event.key === ' ') {{
      go(1);
    }}
    if (event.key === 'ArrowLeft' || event.key === 'PageUp') {{
      go(-1);
    }}
  }});
</script>
</body>
</html>
"""


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--market", default=DEFAULT_MARKET)
    parser.add_argument("--scatter-dir", type=Path, default=Path("scatter"))
    parser.add_argument("--summary", type=Path, default=DEFAULT_OUTPUT_DIR / "aggregate_summary.json")
    parser.add_argument("--risk-chart", type=Path, default=DEFAULT_OUTPUT_DIR / "lender_risk_return.png")
    parser.add_argument("--out", type=Path, default=None)
    args = parser.parse_args()

    scatter_path = latest_scatter(args.scatter_dir, args.market)
    summary = read_summary(args.summary, args.market)
    scatter_html = sanitize_scatter_html(scatter_path.read_text(encoding="utf-8"))
    risk_chart_uri = image_data_uri(args.risk_chart)
    generated_at = datetime.now().astimezone()

    out_path = args.out or DEFAULT_OUTPUT_DIR / f"deck_{args.market[2:10]}_{generated_at.strftime('%Y-%m-%d_%H%M')}.html"
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(
        build_deck(summary, scatter_html, scatter_path, risk_chart_uri, generated_at),
        encoding="utf-8",
    )
    print(f"Deck written to {out_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())


