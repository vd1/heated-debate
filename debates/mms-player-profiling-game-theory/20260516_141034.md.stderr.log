  .nav:hover {{
    background: #ffffff;
    border-color: rgba(17, 24, 39, .28);
  }}
  .nav-prev {{ left: 14px; }}
  .nav-next {{ right: 14px; }}
  @media (max-width: 980px) {{
    .slide {{ padding: 24px; }}
    h1 {{ font-size: 42px; }}
    .stats {{ grid-template-columns: repeat(2, 1fr); }}
    .two-col {{ grid-template-columns: 1fr; }}
    .frame {{ min-height: 70vh; }}
