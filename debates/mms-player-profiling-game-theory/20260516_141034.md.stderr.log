#!/usr/bin/env python3
"""Build a self-contained HTML slide deck from the latest Morpho outputs."""

from __future__ import annotations

import argparse
import base64
import html
import json
from datetime import datetime
from pathlib import Path
from typing import Any


DEFAULT_MARKET = "0x3274643db77a064abd3bc851de77556a4ad2e2f502f4f0c80845fa8f909ecf0b"
DEFAULT_OUTPUT_DIR = Path("output/morpho_positions")


def latest_scatter(scatter_dir: Path, market_key: str) -> Path:
    tag = market_key[2:10]
    matches = sorted(scatter_dir.glob(f"scatter_eM_{tag}_*.html"), key=lambda path: path.stat().st_mtime)
    if not matches:
        raise FileNotFoundError(f"No scatter HTML found for tag {tag} in {scatter_dir}")
    return matches[-1]


def read_summary(path: Path, market_key: str) -> dict[str, Any]:
    data = json.loads(path.read_text(encoding="utf-8"))
    for row in data:
        if row.get("market_key") == market_key:
            return row
    if data:
        return data[0]
    raise ValueError(f"No market summaries found in {path}")


def fmt_money(value: Any) -> str:
    try:
        return f"${float(value):,.0f}"
    except (TypeError, ValueError):
        return "n/a"


def fmt_number(value: Any, digits: int = 2) -> str:
    try:
        return f"{float(value):.{digits}f}"
    except (TypeError, ValueError):
        return "n/a"


def fmt_pct(value: Any, digits: int = 2) -> str:
    try:
        return f"{100 * float(value):.{digits}f}%"
    except (TypeError, ValueError):
        return "n/a"


def image_data_uri(path: Path) -> str:
    encoded = base64.b64encode(path.read_bytes()).decode("ascii")
    return f"data:image/png;base64,{encoded}"


def sanitize_scatter_html(scatter_html: str) -> str:
    """Remove optional external font links from embedded scatter HTML."""
    return "\n".join(
        line
        for line in scatter_html.splitlines()
        if "fonts.googleapis.com" not in line
    )


def stat_card(label: str, value: str) -> str:
    return f'<div class="stat"><span>{html.escape(label)}</span><strong>{html.escape(value)}</strong></div>'


def metric_row(label: str, value: str, note: str = "") -> str:
    note_html = f'<td class="note">{html.escape(note)}</td>' if note else '<td class="note"></td>'
    return f"<tr><th>{html.escape(label)}</th><td>{html.escape(value)}</td>{note_html}</tr>"


def build_deck(
    summary: dict[str, Any],
    scatter_html: str,
    scatter_path: Path,
    risk_chart_uri: str,
    generated_at: datetime,
) -> str:
    label = summary.get("label", "Morpho market")
    market_key = summary.get("market_key", DEFAULT_MARKET)
    supply_source = summary.get("supply_apy_source") or "n/a"
    timestamp = generated_at.strftime("%Y-%m-%d %H:%M:%S")
    scatter_srcdoc = html.escape(scatter_html, quote=True)

    top_stats = "\n".join([
        stat_card("Positions", fmt_number(summary.get("n_positions"), 0)),
        stat_card("Total Debt", fmt_money(summary.get("total_debt_usd"))),
        stat_card("Total Equity", fmt_money(summary.get("total_equity_usd"))),
        stat_card("Supply APY", f"{fmt_pct(summary.get('supply_apy'))} ({supply_source})"),
        stat_card("LLTV", fmt_pct(summary.get("LLTV"), 1)),
        stat_card("Mmax", fmt_number(summary.get("M_max_theoretical"))),
    ])

    metric_rows = "\n".join([
        metric_row("M aggregate", fmt_number(summary.get("M_aggregate")), "total debt / positive equity"),
        metric_row("M median", fmt_number(summary.get("M_median")), "unweighted position median"),
        metric_row("M p90", fmt_number(summary.get("M_p90")), "unweighted position percentile"),
        metric_row("M p50 equity-weighted", fmt_number(summary.get("M_p50_equity_weighted")), "weighted by positive equity"),
        metric_row("M p90 equity-weighted", fmt_number(summary.get("M_p90_equity_weighted")), "weighted by positive equity"),
        metric_row("M p50 debt-weighted", fmt_number(summary.get("M_p50_debt_weighted")), "weighted by borrowAssetsUsd"),
        metric_row("M p90 debt-weighted", fmt_number(summary.get("M_p90_debt_weighted")), "weighted by borrowAssetsUsd"),
        metric_row("M max observed", fmt_number(summary.get("M_max_observed")), "highest borrower leverage"),
        metric_row("delta_A aggregate", fmt_pct(summary.get("delta_A_aggregate")), "aggregate attachment point"),
        metric_row("delta_A worst case", fmt_pct(summary.get("delta_A_worst_case")), "Mmax bound"),
        metric_row("first liquidation", fmt_pct(summary.get("delta_first_liquidation")), "closest borrower threshold"),
    ])

    return f"""<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{html.escape(label)} Morpho Deck</title>
