  }}
  .title-slide {{
    justify-content: center;
    max-width: 1180px;
  }}
  h1, h2 {{
    margin: 0;
    letter-spacing: 0;
    line-height: 1.05;
  }}
  h1 {{ font-size: 64px; font-weight: 650; }}
  h2 {{ font-size: 34px; font-weight: 620; }}
  .subtitle {{
    font-size: 22px;
    color: var(--muted);
    margin-top: 8px;
  }}
  .meta {{
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--muted);
    font-size: 14px;
  }}
