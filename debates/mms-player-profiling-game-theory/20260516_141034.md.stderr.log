    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 8px;
    padding: 14px 16px;
  }}
  .stat span {{
    display: block;
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .04em;
  }}
