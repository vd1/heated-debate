#!/usr/bin/env python3
"""Fetch per-borrower positions from the Morpho Blue GraphQL API.

For each target market (identified by uniqueKey), fetches all borrowing
positions and computes:
  - M_i = borrowAssetsUsd / (collateralUsd - borrowAssetsUsd)  (leverage)
  - delta_i* = 1 - M_i / (LLTV * (1 + M_i))  (individual liquidation threshold)

Outputs a CSV with per-position data and a summary JSON with aggregate
leverage stats for use by morpho_tranche_spread.py.

Usage:
  uv run scripts/fetch_morpho_positions.py
  uv run scripts/fetch_morpho_positions.py --market 0x3274...
"""

from __future__ import annotations

import argparse
import csv
import json
import math
import os
import sys
import time
from pathlib import Path
from typing import Any

ENDPOINT = os.getenv("MORPHO_GQL_URL", "https://api.morpho.org/graphql")
HDRS = {"User-Agent": "MopsusTrancheAnalysis/0.1", "Content-Type": "application/json"}

POSITIONS_QUERY = """
query MarketPositions($marketId: String!, $first: Int!, $skip: Int!) {
  marketPositions(
    where: { marketUniqueKey_in: [$marketId], borrowShares_gte: 1 }
    first: $first
    skip: $skip
    orderBy: BorrowShares
    orderDirection: Desc
  ) {
    pageInfo { count countTotal }
    items {
      user { address }
      supplyShares
      supplyAssets
      supplyAssetsUsd
      borrowShares
      borrowAssets
      borrowAssetsUsd
      collateral
      collateralUsd
      healthFactor
    }
  }
}
"""

MARKET_QUERY = """
query MarketByUniqueKey($marketId: String!) {
  marketByUniqueKey(uniqueKey: $marketId) {
    lltv
    oracleAddress
    collateralAsset { symbol }
    loanAsset { symbol }
  }
}
"""

# Target markets — uniqueKeys from morpho_edges.csv
DEFAULT_TARGETS: dict[str, dict[str, Any]] = {
    # USDT/sUSDS LLTV 96.5%
    "0x3274643db77a064abd3bc851de77556a4ad2e2f502f4f0c80845fa8f909ecf0b": {
        "label": "USDT/sUSDS",
        "lltv": 0.965,
        "sigma": 0.05,
    },
    # USDC/wstETH LLTV 86%
    "usdc_wsteth": {
        "label": "USDC/wstETH",
        "lltv": 0.86,
        "sigma": 0.80,
    },
    # USDS/wstETH LLTV 86%
    "usds_wsteth": {
        "label": "USDS/wstETH",
        "lltv": 0.86,
        "sigma": 0.80,
    },
}

OUT_DIR = Path("output/morpho_positions")
SOY_QUERY_PATH = Path("../soY/pipeline/data/query.json")
SOY_PIPELINE_PATH = Path("../soY/pipeline/data/yield_positive_carry_latest.json")


def to_float(value: Any, default: float = float("nan")) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def read_json_if_exists(path: Path) -> dict[str, Any] | None:
    if not path.exists():
        return None
    try:
        with path.open("r", encoding="utf-8") as fh:
            return json.load(fh)
    except (OSError, json.JSONDecodeError) as exc:
        print(f"[warn] Could not read {path}: {exc}", file=sys.stderr)
        return None


def market_pair(info: dict[str, Any]) -> tuple[str | None, str | None]:
    loan = info.get("loan_symbol")
    collat = info.get("collat_symbol")
    if loan and collat:
        return str(loan), str(collat)

    label = str(info.get("label", ""))
    if "/" in label:
        loan, collat = label.split("/", 1)
        return loan.strip(), collat.strip()
    return None, None


def enrich_with_soy_rates(
    market_key: str,
    info: dict[str, Any],
    query_data: dict[str, Any] | None,
    pipeline_data: dict[str, Any] | None,
) -> None:
    """Attach APYs from the local soY cache when available."""
    loan, collat = market_pair(info)

    pm = None
    for row in (pipeline_data or {}).get("results", []):
        if row.get("uniqueKey") == market_key:
            pm = row
            break
        if loan and collat and row.get("loan") == loan and row.get("collateral") == collat:
            pm = row
            break

    if pm:
        collateral_apy = to_float(pm.get("collateralApy"))
        borrow_apy = to_float(pm.get("borrowApy"))
        if math.isfinite(collateral_apy):
            info["collateral_apy"] = collateral_apy
            info["collateral_apy_source"] = "soY_pipeline"
        if math.isfinite(borrow_apy):
            info["borrow_apy"] = borrow_apy
            info["borrow_apy_source"] = "soY_pipeline"
        supply_usd = to_float(pm.get("supplyUsd"))
        if math.isfinite(supply_usd) and not math.isfinite(to_float(info.get("supply_usd"))):
            info["supply_usd"] = supply_usd

    oracle = str(info.get("oracleAddress") or "").lower()
    oracle_entry = None
    for row in (query_data or {}).get("oracles", []):
        row_oracle = str(row.get("oracle") or "").lower()
        if oracle and row_oracle == oracle:
            oracle_entry = row
            break
        if loan and collat and row.get("loan") == loan and row.get("collateral") == collat:
            oracle_entry = row
            break

    if oracle_entry:
        apy_pct = to_float(oracle_entry.get("apy_smooth_pct"))
        if math.isfinite(apy_pct):
            info["collateral_apy"] = apy_pct / 100.0
            info["collateral_apy_source"] = "soY_query"

    supply_apy = to_float(info.get("supply_apy"))
    collateral_apy = to_float(info.get("collateral_apy"))
    if not math.isfinite(supply_apy) and math.isfinite(collateral_apy):
        info["supply_apy"] = collateral_apy
        info["supply_apy_source"] = info.get("collateral_apy_source", "soY")


def post_gql(query: str, variables: dict) -> dict:
    """Send a GraphQL request. Uses urllib to avoid extra dependencies."""
    import urllib.request
    import urllib.error

    payload = json.dumps({"query": query, "variables": variables}).encode()
    req = urllib.request.Request(ENDPOINT, data=payload, headers=HDRS, method="POST")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        print(f"[error] HTTP {e.code}: {body[:500]}", file=sys.stderr)
        raise


def fetch_positions(market_key: str, page_size: int = 100) -> list[dict]:
    """Paginate through all borrowing positions for a market."""
    all_items: list[dict] = []
    skip = 0
    while True:
        resp = post_gql(POSITIONS_QUERY, {
            "marketId": market_key,
            "first": page_size,
            "skip": skip,
        })
        errors = resp.get("errors")
        if errors:
            print(f"[warn] GraphQL errors: {errors}", file=sys.stderr)
        data = resp.get("data", {}).get("marketPositions", {})
        items = data.get("items", [])
        if not items:
            break
        all_items.extend(items)
        page_info = data.get("pageInfo", {})
        total = page_info.get("countTotal", 0)
        skip += len(items)
        if skip >= total:
            break
        time.sleep(0.3)  # be polite
    return all_items


def parse_lltv(value: Any) -> float:
    """Parse Morpho LLTV values returned either as a fraction or wad integer."""
    raw = float(value or 0)
    if raw > 1:
        return raw / 1e18
    return raw


def fetch_market_info(market_key: str) -> dict[str, Any]:
    """Fetch market metadata needed for custom market runs."""
    resp = post_gql(MARKET_QUERY, {"marketId": market_key})
    errors = resp.get("errors")
    if errors:
        raise RuntimeError(f"GraphQL errors while fetching market metadata: {errors}")
    market = resp.get("data", {}).get("marketByUniqueKey")
    if not market:
        raise ValueError(f"Market not found: {market_key}")

    loan = market.get("loanAsset", {}).get("symbol") or "?"
    collat = market.get("collateralAsset", {}).get("symbol") or "?"
    return {
        "label": f"{loan}/{collat}",
        "lltv": parse_lltv(market.get("lltv")),
        "sigma": guess_sigma(collat, loan),
        "loan_symbol": loan,
        "collat_symbol": collat,
        "oracleAddress": market.get("oracleAddress"),
    }


def compute_position_metrics(pos: dict, lltv: float) -> dict:
    """Compute leverage and liquidation threshold for a single position."""
    borrow_usd = float(pos.get("borrowAssetsUsd") or 0)
    collateral_usd = float(pos.get("collateralUsd") or 0)
    equity = collateral_usd - borrow_usd

    if equity > 0 and borrow_usd > 0:
        m_i = borrow_usd / equity
    elif borrow_usd > 0:
        m_i = float("inf")
    else:
        m_i = 0.0

    # Individual liquidation threshold: delta_i* = 1 - M_i / (ell * (1 + M_i))
    if math.isfinite(m_i) and lltv > 0:
        delta_i = 1.0 - m_i / (lltv * (1.0 + m_i))
    else:
        delta_i = float("-inf")

    # Aggregate attachment point formula: delta_A = 1 - M*ell/(1+M)
    if math.isfinite(m_i):
        delta_a_i = 1.0 - m_i * lltv / (1.0 + m_i)
    else:
        delta_a_i = float("-inf")

    return {
        "user": pos.get("user", {}).get("address", "?"),
        "borrowAssetsUsd": borrow_usd,
        "collateralUsd": collateral_usd,
        "equity": equity,
        "M_i": m_i,
        "delta_i_star": delta_i,
        "delta_A_i": delta_a_i,
        "healthFactor": float(pos.get("healthFactor") or 0),
    }


def weighted_percentile(pairs: list[tuple[float, float]], percentile: float) -> float:
    """Return the weighted percentile for (value, weight) pairs."""
    clean = [
        (value, weight)
        for value, weight in pairs
        if math.isfinite(value) and value > 0 and math.isfinite(weight) and weight > 0
    ]
    if not clean:
        return 0.0

    clean.sort(key=lambda item: item[0])
    total_weight = sum(weight for _, weight in clean)
    threshold = percentile * total_weight
    cumulative = 0.0
    for value, weight in clean:
        cumulative += weight
        if cumulative >= threshold:
            return value
    return clean[-1][0]


def aggregate_metrics(positions: list[dict], lltv: float) -> dict:
    """Compute aggregate leverage and attachment point from position data."""
    total_debt = sum(p["borrowAssetsUsd"] for p in positions)
    total_equity = sum(max(p["equity"], 0) for p in positions)

    if total_equity > 0:
        m_agg = total_debt / total_equity
    else:
        m_agg = float("inf")

    # Aggregate attachment point: delta_A = 1 - M*ell/(1+M)
    if math.isfinite(m_agg):
        delta_a = 1.0 - m_agg * lltv / (1.0 + m_agg)
    else:
        delta_a = 0.0

    # First liquidation trigger: min over individual thresholds
    finite_deltas = [p["delta_i_star"] for p in positions if math.isfinite(p["delta_i_star"])]
    delta_first = min(finite_deltas) if finite_deltas else 0.0

    # M_max bound for comparison
    m_max = lltv / (1.0 - lltv) if lltv < 1.0 else float("inf")
    delta_a_worst = 1.0 - m_max * lltv / (1.0 + m_max) if math.isfinite(m_max) else 0.0

    # Leverage distribution stats
    finite_ms = [p["M_i"] for p in positions if math.isfinite(p["M_i"]) and p["M_i"] > 0]
    m_median = sorted(finite_ms)[len(finite_ms) // 2] if finite_ms else 0.0
    m_max_obs = max(finite_ms) if finite_ms else 0.0
    m_p90 = sorted(finite_ms)[int(0.9 * len(finite_ms))] if len(finite_ms) > 1 else m_max_obs
    equity_weighted_ms = [(p["M_i"], max(p["equity"], 0)) for p in positions]
    debt_weighted_ms = [(p["M_i"], p["borrowAssetsUsd"]) for p in positions]
    m_p50_equity_weighted = weighted_percentile(equity_weighted_ms, 0.50)
    m_p90_equity_weighted = weighted_percentile(equity_weighted_ms, 0.90)
    m_p50_debt_weighted = weighted_percentile(debt_weighted_ms, 0.50)
    m_p90_debt_weighted = weighted_percentile(debt_weighted_ms, 0.90)

    return {
        "n_positions": len(positions),
        "total_debt_usd": total_debt,
        "total_equity_usd": total_equity,
        "M_aggregate": m_agg,
        "M_median": m_median,
        "M_p90": m_p90,
        "M_p50_equity_weighted": m_p50_equity_weighted,
        "M_p90_equity_weighted": m_p90_equity_weighted,
        "M_p50_debt_weighted": m_p50_debt_weighted,
        "M_p90_debt_weighted": m_p90_debt_weighted,
        "M_max_observed": m_max_obs,
        "M_max_theoretical": m_max,
        "delta_A_aggregate": delta_a,
        "delta_A_worst_case": delta_a_worst,
        "delta_first_liquidation": delta_first,
        "LLTV": lltv,
    }


def resolve_market_keys(edges_csv: Path) -> None:
    """Fill in uniqueKeys for label-only targets by matching against edges CSV."""
    if not edges_csv.exists():
        return
    with edges_csv.open("r", encoding="utf-8") as fh:
        reader = csv.DictReader(fh)
        for row in reader:
            loan = (row.get("loan_symbol") or "").upper()
            collat = (row.get("collat_symbol") or "").upper()
            key = row.get("uniqueKey", "")
            for placeholder, info in list(DEFAULT_TARGETS.items()):
                if not placeholder.startswith("0x"):
                    parts = placeholder.split("_")
                    if len(parts) == 2 and parts[0].upper() == loan and parts[1].upper() == collat:
                        if key:
                            DEFAULT_TARGETS[key] = info
                            del DEFAULT_TARGETS[placeholder]
                            break


# Volatility guesses by collateral class
SIGMA_GUESS: dict[str, float] = {
    "WETH": 0.80, "wstETH": 0.80, "weETH": 0.80, "cbETH": 0.80,
    "WBTC": 0.70, "cbBTC": 0.70, "LBTC": 0.70,
    "PAXG": 0.20,
}
STABLECOIN_SIGMA = 0.05
STABLECOINS = {"USDC", "USDT", "USDS", "sUSDS", "sUSDe", "sdeUSD", "PYUSD",
               "RLUSD", "USDtb", "stUSDS", "wsrUSD", "syrupUSDC", "sUSDD",
               "siUSD", "USR", "BONDUSD", "AUSD"}


def guess_sigma(collat_symbol: str, loan_symbol: str) -> float:
    """Heuristic vol for the collateral/loan pair."""
    if collat_symbol in SIGMA_GUESS:
        return SIGMA_GUESS[collat_symbol]
    # stablecoin/stablecoin
    if collat_symbol in STABLECOINS and loan_symbol in STABLECOINS:
        return STABLECOIN_SIGMA
    return 0.60  # unknown — conservative default


def load_top_markets(edges_csv: Path, n: int) -> dict[str, dict[str, Any]]:
    """Load top N markets by supply TVL from edges CSV, filtering junk."""
    if not edges_csv.exists():
        return {}
    with edges_csv.open("r", encoding="utf-8") as fh:
        rows = list(csv.DictReader(fh))
    # Filter: must have uniqueKey, supply > $1M, APY < 100% (filter broken data)
    clean = []
    for r in rows:
        key = r.get("uniqueKey", "")
        supply = float(r.get("supplyUSD") or 0)
        apy = float(r.get("netSupplyAPY_pct") or 0)
        lltv = float(r.get("LLTV_pct") or 0)
        if not key or supply < 1_000_000 or apy > 100 or lltv <= 0:
            continue
        clean.append(r)
    clean.sort(key=lambda r: float(r.get("supplyUSD") or 0), reverse=True)
    targets = {}
    for r in clean[:n]:
        key = r["uniqueKey"]
        loan = r.get("loan_symbol", "?")
        collat = r.get("collat_symbol", "?")
        lltv = float(r.get("LLTV_pct", 0)) / 100.0
        supply_apy = float(r.get("netSupplyAPY_pct", 0)) / 100.0
        sigma = guess_sigma(collat, loan)
        targets[key] = {
            "label": f"{loan}/{collat}",
            "lltv": lltv,
            "sigma": sigma,
            "supply_apy": supply_apy,
            "supply_apy_source": "edges_csv",
            "supply_usd": float(r.get("supplyUSD", 0)),
            "loan_symbol": loan,
            "collat_symbol": collat,
        }
    return targets


def compute_implied_vol(delta_a: float, supply_apy: float, T: float = 7 / 365) -> float:
    """Back out the σ that makes supply_apy = fair_spread(δ_A, σ, T).

    Solves:  Φ(-δ_A / (σ√T)) = 1 - exp(-APY·T)
    for σ, using Brent's method.
    """
    try:
        from scipy.optimize import brentq
        from scipy.stats import norm
    except ImportError:
        return float("nan")

    if delta_a <= 0 or supply_apy <= 0 or not math.isfinite(delta_a):
        return float("nan")

    target_prob = 1.0 - math.exp(-supply_apy * T)
    if target_prob <= 0 or target_prob >= 1:
        return float("nan")

    sqrtT = math.sqrt(T)

    def residual(sigma: float) -> float:
        return norm.sf(delta_a / (sigma * sqrtT)) - target_prob

    try:
        return brentq(residual, 1e-4, 50.0, xtol=1e-6)
    except ValueError:
        return float("nan")


def plot_scatter(summaries: list[dict], out_path: Path) -> None:
    """Generate (delta_A, supply APY) scatter with fair-pricing curve."""
    try:
        import matplotlib
        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
        import numpy as np
    except ImportError:
        print("[warn] matplotlib not available, skipping plot")
        return

    from matplotlib.colors import LogNorm
    import matplotlib.cm as cm

    fig, ax = plt.subplots(1, 1, figsize=(11, 7))

    # Compute implied vol for each market and build arrays
    xs, ys, labels, iv_ratios = [], [], [], []
    for s in summaries:
        da = s.get("delta_A_aggregate", 0)
        apy = s.get("supply_apy", 0)
        if da <= 0 or not math.isfinite(da) or not math.isfinite(apy):
            continue
        xs.append(100 * da)
        ys.append(100 * apy)
        labels.append(s.get("label", "?"))

        sigma_realized = s.get("sigma", 0.5)
        sigma_imp = compute_implied_vol(da, apy)
        ratio = sigma_imp / sigma_realized if (math.isfinite(sigma_imp) and sigma_realized > 0) else float("nan")
        iv_ratios.append(ratio)
        s["sigma_implied"] = sigma_imp
        s["iv_ratio"] = ratio

    if not xs:
        print("[warn] no finite APY/attachment points available, skipping plot")
        return

    # Color by IV/realized ratio (log scale); clamp for colormap
    finite_ratios = [r for r in iv_ratios if math.isfinite(r) and r > 0]
    if finite_ratios:
        vmin = max(min(finite_ratios), 0.1)
        vmax = min(max(finite_ratios), 100)
        if vmin >= vmax:
            vmin = max(vmin / 2, 1e-6)
            vmax = vmax * 2
    else:
        vmin, vmax = 0.5, 5.0
    cmap = cm.RdYlGn_r  # red = high ratio (mispriced), green = fairly priced
    norm = LogNorm(vmin=vmin, vmax=vmax)
    plot_colors = []
    for r in iv_ratios:
        if math.isfinite(r) and r > 0:
            plot_colors.append(cmap(norm(r)))
        else:
            plot_colors.append("grey")

    sc = ax.scatter(xs, ys, c=plot_colors, s=90, zorder=5, edgecolors="white", linewidth=0.5)

    # Add colorbar for IV ratio
    sm = cm.ScalarMappable(cmap=cmap, norm=norm)
    sm.set_array([])
    cbar = fig.colorbar(sm, ax=ax, pad=0.02, shrink=0.8)
    cbar.set_label(r"$\sigma_{imp} / \sigma_{realized}$  (>1 = underpriced)", fontsize=10)

    # Label each point, with automatic repulsion when adjustText is available.
    texts = [ax.text(x, y, label, fontsize=7, alpha=0.85) for x, y, label in zip(xs, ys, labels)]
    try:
        from adjustText import adjust_text
    except ImportError:
        print("[warn] adjustText not available, labels may overlap")
    else:
        adjust_text(texts, x=xs, y=ys, ax=ax,
                    arrowprops=dict(arrowstyle="-", color="grey", alpha=0.4, lw=0.5),
                    expand=(1.5, 1.8), force_text=(0.8, 1.0),
                    force_points=(0.3, 0.4), max_move=50)

    # Fair-pricing curves for two vol regimes
    try:
        from scipy.stats import norm
    except ImportError:
        print("[warn] scipy not available, skipping fair-pricing curves")
    else:
        da_range = np.linspace(0.5, 80, 200)
        for sigma, ls, clr, lbl in [
            (0.80, "--", "#2980b9", r"fair ($\sigma$=80%, ETH)"),
            (0.05, ":", "#e74c3c", r"fair ($\sigma$=5%, stablecoin)"),
        ]:
            scale = sigma * np.sqrt(7 / 365)
            probs = norm.sf(da_range / 100 / scale)
            fair = -np.log(1 - np.clip(probs, 0, 1 - 1e-6)) / (7 / 365)
            ax.plot(da_range, 100 * fair, ls=ls, color=clr, alpha=0.6, label=lbl)

    ax.set_xlabel(r"$\delta_A$ — attachment point (% collateral drop)", fontsize=11)
    ax.set_ylabel("Supply APY (%)", fontsize=11)
    ax.set_title("Morpho Markets: Lender Risk–Return\n"
                 r"(markets below fair-pricing curve undercompensate lenders)",
                 fontsize=12)
    ax.legend(fontsize=9, loc="upper right")
    ax.set_xlim(0, 80)
    ax.set_ylim(0, max(ys) * 1.3 if ys else 10)
    ax.grid(True, alpha=0.3)

    fig.tight_layout()
    fig.savefig(out_path, dpi=150)
    print(f"\nChart saved: {out_path}")
    plt.close(fig)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--market", type=str, default=None,
                        help="Single market uniqueKey to query (overrides defaults)")
    parser.add_argument("--top", type=int, default=0,
                        help="Sweep top N markets by TVL from edges CSV")
    parser.add_argument("--edges", type=Path,
                        default=Path("output/morpho_graph/morpho_edges.csv"))
    parser.add_argument("--out", type=Path, default=OUT_DIR)
    parser.add_argument("--plot", type=Path, default=None,
                        help="Output path for scatter plot PNG")
    args = parser.parse_args()

    args.out.mkdir(parents=True, exist_ok=True)

    if args.market:
        targets = {args.market: fetch_market_info(args.market)}
    elif args.top > 0:
        targets = load_top_markets(args.edges, args.top)
    else:
        resolve_market_keys(args.edges)
        targets = {k: v for k, v in DEFAULT_TARGETS.items() if k.startswith("0x")}

    if not targets:
        print("[error] No valid market keys found. Pass --market or check edges CSV.", file=sys.stderr)
        return 1

    query_data = read_json_if_exists(SOY_QUERY_PATH)
    pipeline_data = read_json_if_exists(SOY_PIPELINE_PATH)
    for market_key, info in targets.items():
        enrich_with_soy_rates(market_key, info, query_data, pipeline_data)

    summaries = []
    for market_key, info in targets.items():
        label = info["label"]
        lltv = info["lltv"]
        print(f"\n{'='*60}")
        print(f"Fetching positions for {label} ({market_key[:16]}...)")

        raw = fetch_positions(market_key)
        if not raw:
            print(f"  [warn] No borrowing positions found")
            continue

        positions = sorted(
            (compute_position_metrics(p, lltv) for p in raw),
            key=lambda p: p["equity"],
            reverse=True,
        )
        agg = aggregate_metrics(positions, lltv)
        agg["label"] = label
        agg["market_key"] = market_key
        agg["supply_apy"] = info.get("supply_apy", float("nan"))
        agg["supply_apy_source"] = info.get("supply_apy_source", "")
        agg["collateral_apy"] = info.get("collateral_apy", float("nan"))
        agg["collateral_apy_source"] = info.get("collateral_apy_source", "")
        agg["borrow_apy"] = info.get("borrow_apy", float("nan"))
        agg["borrow_apy_source"] = info.get("borrow_apy_source", "")
        agg["supply_usd"] = info.get("supply_usd", 0)
        agg["sigma"] = info.get("sigma", 0.80)
        summaries.append(agg)

        # Print summary
        print(f"  Positions: {agg['n_positions']}")
        print(f"  Total debt: ${agg['total_debt_usd']:,.0f}")
        print(f"  Total equity: ${agg['total_equity_usd']:,.0f}")
        print(f"  M_aggregate: {agg['M_aggregate']:.2f}")
        print(f"  M_median: {agg['M_median']:.2f}  M_p90: {agg['M_p90']:.2f}  M_max_obs: {agg['M_max_observed']:.2f}")
        print(f"  M_equity_wtd_p50: {agg['M_p50_equity_weighted']:.2f}  M_equity_wtd_p90: {agg['M_p90_equity_weighted']:.2f}")
        print(f"  M_debt_wtd_p50: {agg['M_p50_debt_weighted']:.2f}  M_debt_wtd_p90: {agg['M_p90_debt_weighted']:.2f}")
        if math.isfinite(to_float(agg["supply_apy"])):
            print(f"  Supply APY: {100*agg['supply_apy']:.2f}% ({agg['supply_apy_source']})")
        print(f"  delta_A (aggregate): {100*agg['delta_A_aggregate']:.2f}%")
        print(f"  delta_A (M_max bound): {100*agg['delta_A_worst_case']:.2f}%")
        print(f"  delta_first_liq: {100*agg['delta_first_liquidation']:.2f}%")

        # Write per-position CSV
        pos_path = args.out / f"positions_{label.replace('/', '_')}.csv"
        fieldnames = ["user", "borrowAssetsUsd", "collateralUsd", "equity",
                      "M_i", "delta_i_star", "delta_A_i", "healthFactor"]
        with pos_path.open("w", encoding="utf-8", newline="") as fh:
            writer = csv.DictWriter(fh, fieldnames=fieldnames)
            writer.writeheader()
            writer.writerows(positions)
        print(f"  Positions written to {pos_path}")

    # Write aggregate summary
    if summaries:
        summary_path = args.out / "aggregate_summary.json"
        with summary_path.open("w", encoding="utf-8") as fh:
            json.dump(summaries, fh, indent=2, default=str)
        print(f"\nAggregate summary: {summary_path}")

        # Generate plot
        plot_path = args.plot or (args.out / "lender_risk_return.png")
        plot_scatter(summaries, plot_path)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())


