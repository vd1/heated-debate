#!/usr/bin/env python3
"""Compute wash-lending attachment points and implied spreads for Morpho markets.

The script ingests the watcher export (morpho_edges.csv) produced by
KilDef/scripts/build_morpho_graph.py.

NOTE: The CSV only has aggregate pool data, not per-borrower positions.
As a proxy we use M_max = LLTV / (1 - LLTV), the worst-case leverage
assuming every borrower maxes out their LLTV.  This gives a *lower bound*
on the attachment point (worst case for senior).  For true M_i distributions,
query the Morpho Blue subgraph for per-position collateral/debt.

Attachment point formula (from washLending.tex, homogeneous case):
  delta_A = 1 - M * LLTV / (1 + M)

For each target market we then estimate:
  * breach probability over the chosen horizon given a volatility guess
  * the "fair" senior spread implied by that tail probability
  * the observed borrow rate (approximated as supplyAPY / util when direct
    borrow quotes are unavailable in the watcher export)

Outputs a CSV plus a human-readable table so the results can feed the
wash-lending tranche write-up.
"""

from __future__ import annotations

import argparse
import csv
import json
import math
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


REPO_ROOT = Path(__file__).resolve().parent
WORKTREE_ROOT = REPO_ROOT
DEFAULT_EDGES = WORKTREE_ROOT / "output/morpho_graph/morpho_edges.csv"
DEFAULT_MARKETS = WORKTREE_ROOT.parents[0] / "KilDef" / "discovery" / "morpho" / "morpho_markets_all.csv"


@dataclass
class MarketTarget:
    loan: str
    collat: str
    chain_id: int = 1
    sigma: float = 0.80  # annualized vol assumption
    horizon_days: float = 7.0
    lgd: float = 1.0     # loss-given-default assumption
    nickname: Optional[str] = None

    def label(self) -> str:
        base = f"{self.loan}/{self.collat} @ chain {self.chain_id}"
        return f"{self.nickname} ({base})" if self.nickname else base


def parse_float(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def load_edges(path: Path) -> List[Dict[str, Any]]:
    if not path.exists():
        raise FileNotFoundError(f"edges CSV not found: {path}")
    with path.open("r", encoding="utf-8") as fh:
        reader = csv.DictReader(fh)
        return list(reader)


def load_market_meta(path: Path) -> Dict[str, Dict[str, Any]]:
    if not path or not path.exists():
        return {}
    with path.open("r", encoding="utf-8") as fh:
        reader = csv.DictReader(fh)
        return {row.get("uniqueKey", ""): row for row in reader if row.get("uniqueKey")}


def find_row(edges: List[Dict[str, Any]], target: MarketTarget) -> Dict[str, Any]:
    matches = [
        row for row in edges
        if (row.get("loan_symbol") or "").upper() == target.loan.upper()
        and (row.get("collat_symbol") or "").upper() == target.collat.upper()
        and int(parse_float(row.get("chainId"), default=0)) == target.chain_id
    ]
    if not matches:
        available = sorted({(row.get("loan_symbol"), row.get("collat_symbol")) for row in edges})
        raise ValueError(f"No market found for {target.label()}. "
                         f"Available sample: {available[:5]}")
    if len(matches) > 1:
        # If multiple markets (e.g. different deployments) exist, pick the largest by borrow USD.
        matches.sort(key=lambda r: parse_float(r.get("borrowUSD"), default=0.0), reverse=True)
    return matches[0]


def normal_tail_probability(delta_a: float, sigma: float, horizon_days: float) -> float:
    """Approximate P(delta > delta_A) assuming N(0, sigma*sqrt(t))."""
    if sigma <= 0 or horizon_days <= 0:
        return 0.0
    scale = sigma * math.sqrt(horizon_days / 365.0)
    if scale <= 0:
        return 0.0
    z = delta_a / scale
    # tail probability = 0.5 * erfc(z / sqrt(2))
    return 0.5 * math.erfc(z / math.sqrt(2.0))


def fair_spread(prob: float, lgd: float, horizon_days: float) -> float:
    """Return annualized fair spread (as fraction) given tail probability and LGD."""
    tau_years = horizon_days / 365.0
    if prob <= 0 or lgd <= 0 or tau_years <= 0:
        return 0.0
    # Clamp to avoid log(<=0)
    loss_prob = min(max(prob * lgd, 1e-12), 1 - 1e-6)
    return -math.log(1 - loss_prob) / tau_years


def approx_borrow_rate(meta_row: Optional[Dict[str, Any]]) -> float:
    """Approximate borrow APY as supplyAPY / util (reserve factor ignored)."""
    if not meta_row:
        return float("nan")
    supply_apy = parse_float(meta_row.get("supplyAPY"))
    util = parse_float(meta_row.get("util"))
    if util <= 0:
        return float("nan")
    return supply_apy / util


def compute_metrics(
    row: Dict[str, Any],
    target: MarketTarget,
    meta_row: Optional[Dict[str, Any]],
) -> Dict[str, Any]:
    supply = parse_float(row.get("supplyUSD"))
    liquidity = parse_float(row.get("liquidityUSD"))
    borrow = parse_float(row.get("borrowUSD"))
    if borrow == 0.0 and liquidity and supply:
        borrow = max(supply - liquidity, 0.0)
    lltv_pct = parse_float(row.get("LLTV_pct"))
    lltv = lltv_pct / 100.0 if lltv_pct else 0.0
    util_pct = parse_float(row.get("util_pct"))
    util = util_pct / 100.0 if util_pct else 0.0

    # M_max = LLTV / (1 - LLTV): worst-case leverage if every borrower
    # maxes out their collateral ratio.  This is a lower bound on delta_A.
    m_mult = lltv / (1.0 - lltv) if lltv < 1.0 else float("inf")
    delta_a = float("nan")
    if lltv > 0 and math.isfinite(m_mult):
        # Correct attachment point formula: delta_A = 1 - M*ell/(1+M)
        delta_a = 1.0 - m_mult * lltv / (1.0 + m_mult)
    prob = normal_tail_probability(max(delta_a, 0.0), target.sigma, target.horizon_days)
    spread = fair_spread(prob, target.lgd, target.horizon_days)
    borrow_rate = approx_borrow_rate(meta_row)

    return {
        "loan": row.get("loan_symbol") or row.get("loan_addr"),
        "collat": row.get("collat_symbol") or row.get("collat_addr"),
        "uniqueKey": row.get("uniqueKey"),
        "supplyUSD": supply,
        "borrowUSD": borrow,
        "liquidityUSD": liquidity,
        "LLTV_pct": lltv_pct,
        "util_pct": util_pct,
        "M": m_mult,
        "delta_A": delta_a,
        "sigma": target.sigma,
        "horizon_days": target.horizon_days,
        "tail_prob": prob,
        "fair_spread": spread,
        "approx_borrow_rate": borrow_rate,
        "lgd": target.lgd,
        "label": target.label(),
    }


def write_csv(rows: List[Dict[str, Any]], path: Path) -> None:
    if not rows:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    fieldnames = [
        "label", "loan", "collat", "uniqueKey",
        "supplyUSD", "borrowUSD", "liquidityUSD",
        "LLTV_pct", "util_pct", "M", "delta_A",
        "sigma", "horizon_days", "tail_prob",
        "fair_spread", "approx_borrow_rate", "lgd",
    ]
    with path.open("w", encoding="utf-8", newline="") as fh:
        writer = csv.DictWriter(fh, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows({k: row.get(k) for k in fieldnames} for row in rows)


def format_row(row: Dict[str, Any]) -> str:
    def fmt_dollar(value: float) -> str:
        if math.isnan(value) or value is None:
            return "n/a"
        return f"${value:,.0f}"

    def fmt_pct(value: float) -> str:
        if value is None or math.isnan(value):
            return "n/a"
        return f"{100*value:.2f}%"

    return (
        f"{row['label']:<32} "
        f"M_max={row['M']:.2f}  "
        f"δ_A={fmt_pct(row['delta_A'])}  "
        f"supply={fmt_dollar(row['supplyUSD'])}  "
        f"borrow={fmt_dollar(row['borrowUSD'])}  "
        f"liq={fmt_dollar(row['liquidityUSD'])}  "
        f"tail={fmt_pct(row['tail_prob'])}  "
        f"fair={fmt_pct(row['fair_spread'])}  "
        f"obs≈{fmt_pct(row['approx_borrow_rate'])}"
    )


def build_targets(custom: Optional[str]) -> List[MarketTarget]:
    preset = [
        MarketTarget(loan="USDT", collat="sUSDS", sigma=0.05, horizon_days=7, nickname="USDT/sUSDS"),
        MarketTarget(loan="USDS", collat="wstETH", sigma=0.80, horizon_days=7, nickname="USDS/wstETH"),
        MarketTarget(loan="USDC", collat="wstETH", sigma=0.80, horizon_days=7, nickname="USDC/wstETH"),
        MarketTarget(loan="USDC", collat="cbETH", sigma=0.80, horizon_days=7, nickname="USDC/cbETH"),
        MarketTarget(loan="USDT", collat="USDS", sigma=0.05, horizon_days=7, nickname="USDT/USDS (LLTV 97%)"),
    ]
    if not custom:
        return preset
    parsed: List[MarketTarget] = []
    for item in custom.split(","):
        parts = item.strip().split("/")
        if len(parts) != 2:
            raise ValueError(f"Invalid market spec '{item}'. Use loan/collat format.")
        parsed.append(MarketTarget(loan=parts[0].strip(), collat=parts[1].strip()))
    return parsed


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--edges", type=Path, default=DEFAULT_EDGES,
                        help="Path to morpho_edges.csv (default: output/morpho_graph/morpho_edges.csv)")
    parser.add_argument("--markets", type=str, default=None,
                        help="Comma-separated loan/collat overrides (e.g. 'USDT/sUSDS,USDC/wstETH').")
    parser.add_argument("--markets-csv", type=Path, default=DEFAULT_MARKETS,
                        help="Optional morpho_markets_all.csv path for supplyAPY/util data.")
    parser.add_argument("--out", type=Path,
                        default=Path("output/morpho_tranche_report.csv"),
                        help="CSV output path (default: output/morpho_tranche_report.csv)")
    parser.add_argument("--json", type=Path,
                        default=Path("output/morpho_tranche_report.json"),
                        help="Optional JSON dump of the computed rows.")
    args = parser.parse_args()

    edges = load_edges(args.edges)
    meta = load_market_meta(args.markets_csv) if args.markets_csv else {}
    targets = build_targets(args.markets)
    results: List[Dict[str, Any]] = []
    missing: List[Tuple[MarketTarget, str]] = []
    for target in targets:
        try:
            row = find_row(edges, target)
        except ValueError as exc:
            missing.append((target, str(exc)))
            continue
        meta_row = meta.get(row.get("uniqueKey", ""))
        metrics = compute_metrics(row, target, meta_row)
        results.append(metrics)
        print(format_row(metrics))

    for target, msg in missing:
        print(f"[warn] {target.label()}: {msg}")

    write_csv(results, args.out)
    if args.json:
        args.json.parent.mkdir(parents=True, exist_ok=True)
        with args.json.open("w", encoding="utf-8") as fh:
            json.dump(results, fh, indent=2)
    if missing:
        print(f"[warn] missing {len(missing)} market(s); see warnings above.")
    return 0 if results else 1


if __name__ == "__main__":
    raise SystemExit(main())


