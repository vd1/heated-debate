+
+def _format_utc_ts(ts: datetime) -> str:
+    return ts.replace(microsecond=0).isoformat().replace("+00:00", "Z")
+
+
+def _truncate_error_summary(text: str, max_len: int = BLACKBOARD_ERROR_SUMMARY_MAX_LEN) -> str:
+    normalized = " ".join(text.split()) or "unknown error"
+    if len(normalized) <= max_len:
+        return normalized
+    return normalized[: max_len - 1].rstrip() + "…"
+
+
+def _health_state(chat_id: int) -> BlackboardHealth:
