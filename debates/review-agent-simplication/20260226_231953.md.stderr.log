+
+
+def _prune_blackboard_failures(chat_id: int, *, now: datetime | None = None) -> list[datetime]:
+    state = _blackboard_health.get(chat_id)
+    if state is None:
+        return []
+    current = now or _utc_now()
+    cutoff = current - BLACKBOARD_HEALTH_WINDOW
+    state.failure_timestamps = [ts for ts in state.failure_timestamps if ts >= cutoff]
+    return state.failure_timestamps
+
+
+def _mark_blackboard_failure(chat_id: int, err: Exception) -> None:
