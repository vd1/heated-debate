    }

    /* ── Nav ── */
    .nav {
      position: fixed;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 16px;
      z-index: 100;
      background: rgba(19, 19, 30, 0.85);
