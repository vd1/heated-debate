      <div class="sep" style="margin: 24px auto;"></div>
      <div class="codeblock mt16" style="max-width:620px; font-size:16px; text-align:left;">
        <span class="comment"># install bun, clone, debate</span>
        <span class="cmd">bun shelley.ts</span> <span class="kw">-f</span> debates/stock-trades/topic.md <span
          class="str">5</span>
      </div>
      <div class="chips mt40">
        <div class="chip">
          <div class="chip-dot" style="background:var(--accent1)"></div>github.com/vd1/heated-debate
        </div>
        <div class="chip">
          <div class="chip-dot" style="background:var(--accent3)"></div>shelley.ts · bun
        </div>
