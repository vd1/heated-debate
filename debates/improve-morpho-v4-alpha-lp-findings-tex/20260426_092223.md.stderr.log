\section{Main Artifacts}

\begin{longtable}{p{0.38\linewidth}p{0.52\linewidth}}
\toprule
Artifact & Contents \\
\midrule
\file{data/morpho_v4_raw_logs.json} & PoolManager logs for the selected MORPHO/ETH pool. \\
