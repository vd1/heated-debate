# -*- coding: utf-8 -*-
"""Shared adapter infrastructure for neighborhood venue adapters."""

from __future__ import annotations

import importlib.util
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional, Set

from neighborhood_common import Graph, Node, normalize_addr
from providers import http_client
from utils import get_logger

log = get_logger("neigh")

_WATCHER_MODULE_CACHE: Dict[str, Any] = {}


def _load_watch_module(filename: str, import_name: str):
    if import_name in _WATCHER_MODULE_CACHE:
        module = _WATCHER_MODULE_CACHE[import_name]
        return None if module is False else module

    module_path = Path(__file__).resolve().parents[1] / "watchers" / filename
    if not module_path.exists():
        log.warning("Watcher not found at %s", module_path)
        _WATCHER_MODULE_CACHE[import_name] = False
        return None

    try:
        watchers_dir = str(module_path.parent)
        repo_root = str(module_path.parents[1])
        for path in (watchers_dir, repo_root):
            if path not in sys.path:
                sys.path.insert(0, path)
        spec = importlib.util.spec_from_file_location(import_name, module_path)
        if spec is None or spec.loader is None:
            raise ImportError(f"Cannot create import spec for {module_path}")
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        _WATCHER_MODULE_CACHE[import_name] = module
        return module
    except Exception as exc:
        log.warning("Failed to load watcher %s: %s", filename, exc)
        _WATCHER_MODULE_CACHE[import_name] = False
        return None


def fetch_aave_markets_for_chain(chain_id: int) -> List[Dict[str, Any]]:
    module = _load_watch_module("aaveWatch.py", "kildef_watchers.aaveWatch")
    if module is None:
        return []
    return module.fetch_markets([int(chain_id)])


def fetch_morpho_markets_for_chain(chain_id: int) -> List[Dict[str, Any]]:
    module = _load_watch_module("morphoWatch.py", "kildef_watchers.morphoWatch")
    if module is None:
        return []
    return module.fetch_markets([int(chain_id)])


def fetch_euler_markets_for_chain(chain_id: int) -> List[Dict[str, Any]]:
    if int(chain_id) != 1:
        return []
    module = _load_watch_module("eulerWatch.py", "kildef_watchers.eulerWatch")
    if module is None:
        return []
    raw = module.fetch_markets_from_subgraph()
    rows, _ = module.to_rows(raw, {}, None)
    return rows


def _token_nodes_by_chain(graph: Graph, eligible_ids: Optional[Set[str]] = None) -> Dict[int, Dict[str, Node]]:
    token_nodes: Dict[int, Dict[str, Node]] = {}
    for node in graph.nodes.values():
        if node.kind != "token" or not node.address:
            continue
        if eligible_ids is not None and node.id not in eligible_ids:
            continue
        token_nodes.setdefault(int(node.chainId), {})[node.address.lower()] = node
    return token_nodes


_PENDLE_EXPIRY_CACHE: Dict[int, Set[str]] = {}


def _parse_pendle_addr(token_id: str) -> Optional[str]:
    """Extract address from Pendle token id like '1-0xabc...'."""
    if not token_id or "-" not in token_id:
        return None
    return normalize_addr(token_id.split("-", 1)[1])


def fetch_expired_pendle_addresses(chain_id: int) -> Set[str]:
    """Return expired Pendle PT, YT, and orphaned SY addresses for *chain_id*.

    An SY is considered expired when ALL markets that reference it are expired.
    """
    if chain_id in _PENDLE_EXPIRY_CACHE:
        return _PENDLE_EXPIRY_CACHE[chain_id]

    expired: Set[str] = set()
    now = datetime.now(timezone.utc)

    # Fetch all markets (paginated)
    all_markets: List[Dict[str, Any]] = []
    skip = 0
    while True:
        try:
            resp = http_client.get(
                "https://api-v2.pendle.finance/core/v2/markets/all",
                params={"chainId": chain_id, "limit": 100, "skip": skip},
            )
            data = resp.json()
            results = data.get("results") or []
        except Exception as exc:
            log.warning("Pendle markets fetch failed for chain %s: %s", chain_id, exc)
            break
        if not results:
            break
        all_markets.extend(results)
        skip += len(results)
        if skip >= (data.get("total") or 0):
            break

    # Track SY → {has_active_market}
    sy_has_active: Dict[str, bool] = {}

    for market in all_markets:
        expiry_str = market.get("expiry")
        if not expiry_str:
            continue
        try:
            expiry = datetime.fromisoformat(expiry_str.replace("Z", "+00:00"))
        except (ValueError, TypeError):
            continue

        is_expired = expiry < now

        pt_addr = _parse_pendle_addr(market.get("pt") or "")
        yt_addr = _parse_pendle_addr(market.get("yt") or "")
        sy_addr = _parse_pendle_addr(market.get("sy") or "")

        if is_expired:
            if pt_addr:
                expired.add(pt_addr)
            if yt_addr:
                expired.add(yt_addr)
        else:
            # Active market — its SY is still live
            if sy_addr:
                sy_has_active[sy_addr] = True

        # Register SY if not already marked active
        if sy_addr and sy_addr not in sy_has_active:
            sy_has_active.setdefault(sy_addr, False)

    # SYs where all markets are expired
    for sy_addr, has_active in sy_has_active.items():
        if not has_active:
            expired.add(sy_addr)

    _PENDLE_EXPIRY_CACHE[chain_id] = expired
    log.debug("Pendle: %d expired tokens on chain %s", len(expired), chain_id)
    return expired


def _enrich_token_node(token_node: Node, *, symbol: Optional[str] = None, label: Optional[str] = None, project: Optional[str] = None) -> None:
    if symbol and not token_node.symbol:
        token_node.symbol = symbol
    if label and (not token_node.label or token_node.label == token_node.address):
        token_node.label = label
    if project and not token_node.project:
        token_node.project = project


