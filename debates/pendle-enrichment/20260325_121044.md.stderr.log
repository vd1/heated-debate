# -*- coding: utf-8 -*-
"""Aave v3 venue adapter for neighborhood graph."""

from __future__ import annotations

from typing import Any, Optional, Set

from neighborhood_common import Edge, Graph, Node, node_id, normalize_addr
from neigh_helpers import (
    _enrich_token_node,
    _token_nodes_by_chain,
    fetch_aave_markets_for_chain,
)
from utils import get_logger, safe_float

log = get_logger("neigh")


def _extract_aave_percent(data: Any) -> Optional[float]:
    if isinstance(data, dict):
        data = data.get("value")
    return safe_float(data, default=None)


def _extract_aave_usd(data: Any) -> Optional[float]:
    if isinstance(data, dict):
        data = data.get("usd")
    return safe_float(data, default=None)


def _attach_aave_market_nodes(graph: Graph, eligible_ids: Optional[Set[str]] = None) -> None:
    token_nodes_by_chain = _token_nodes_by_chain(graph, eligible_ids=eligible_ids)
    if not token_nodes_by_chain:
        return

    for chain_id, token_nodes in token_nodes_by_chain.items():
        try:
            markets = fetch_aave_markets_for_chain(chain_id)
        except Exception as exc:
            log.warning("Aave market fetch failed for chain %s: %s", chain_id, exc)
            continue

        for market in markets:
            market_name = market.get("name") or "Aave v3"
            market_addr = normalize_addr(market.get("address"))
            if not market_addr:
                continue

            for reserve in market.get("reserves") or []:
                underlying = reserve.get("underlyingToken") or {}
                asset_addr = normalize_addr(underlying.get("address"))
                if not asset_addr:
                    continue

                token_node = token_nodes.get(asset_addr)
                if token_node is None:
                    continue
                supply = reserve.get("supplyInfo") or {}
                borrow = reserve.get("borrowInfo") or {}
                asset_symbol = underlying.get("symbol") or token_node.symbol or "token"
                _enrich_token_node(token_node, symbol=asset_symbol, label=asset_symbol)
                market_node_id = node_id(chain_id, "lending_market", f"aave:{market_addr}:{asset_addr}")

                market_node = Node(
                    id=market_node_id,
                    address=market_addr,
                    chainId=chain_id,
                    kind="lending_market",
                    label=f"{asset_symbol} reserve @ {market_name}",
                    symbol=asset_symbol,
                    role="other",
                    protocol="aave-v3",
                    project="Aave",
                    tvl=_extract_aave_usd(reserve.get("size")),
                    apy_base=_extract_aave_percent(supply.get("apy")),
                    source="aaveWatch",
                    extra={
                        "market_name": market_name,
                        "market_address": market_addr,
                        "asset_address": asset_addr,
                        "can_be_collateral": bool(supply.get("canBeCollateral")),
                        "max_ltv": _extract_aave_percent(supply.get("maxLTV")),
                        "liq_threshold": _extract_aave_percent(supply.get("liquidationThreshold")),
                        "liq_bonus": _extract_aave_percent(supply.get("liquidationBonus")),
                        "liquidity_usd": _extract_aave_usd(borrow.get("availableLiquidity")),
                        "borrow_usd": _extract_aave_usd(borrow.get("total")),
                        "borrow_apy": _extract_aave_percent(borrow.get("apy")),
                        "utilization": _extract_aave_percent(borrow.get("utilizationRate")),
                        "oracle": normalize_addr(reserve.get("usdOracleAddress")),
                    },
                )
                graph.add_node(market_node)
                graph.add_edge(Edge(
                    src=token_node.id,
                    dst=market_node.id,
                    type="LEND",
                    notes="aave reserve",
                    source="aaveWatch",
                ))

                if bool(supply.get("canBeCollateral")):
                    max_ltv = _extract_aave_percent(supply.get("maxLTV"))
                    note = None if max_ltv is None else f"maxLTV={max_ltv:.4f}"
                    graph.add_edge(Edge(
                        src=token_node.id,
                        dst=market_node.id,
                        type="PLEDGE",
                        notes=note,
                        source="aaveWatch",
                    ))


