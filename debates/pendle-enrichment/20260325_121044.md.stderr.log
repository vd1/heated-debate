"""Shared neighborhood graph model and Enso payload helpers."""

from __future__ import annotations

import json
from dataclasses import asdict, dataclass, field, fields
from typing import Any, Dict, Optional, Set, Tuple, List
from urllib.parse import quote

__all__ = [
    "Price",
    "Node",
    "Edge",
    "Graph",
    "normalize_addr",
    "node_id",
    "token_node_id",
    "infer_role_from_enso",
    "edge_type_for_source_role",
    "node_from_enso_payload",
]


def normalize_addr(addr: Optional[str]) -> Optional[str]:
    if not isinstance(addr, str):
        return None
    addr = addr.strip()
    if addr.startswith("0x") and len(addr) == 42:
        return addr.lower()
    return None


def _normalize_node_key(key: Any) -> str:
    raw = str(key).strip()
    if not raw:
        raise ValueError("Node key must not be blank")
    if raw.startswith("0x") and len(raw) == 42:
        raw = raw.lower()
    return quote(raw, safe="")


def node_id(chain_id: int, address_or_namespace: str, key: Optional[str] = None) -> str:
    """
    Build a stable node id.

    Backward-compatible token form:
      node_id(1, "0x...")

    Generic form for non-token entities:
      node_id(1, "lending_market", "morpho-blue:0x...")
    """
    if key is None:
        namespace = "erc20"
        raw_key = address_or_namespace
    else:
        namespace = str(address_or_namespace).strip().lower()
        if not namespace:
            raise ValueError("Node namespace must not be blank")
        raw_key = key
    return f"eip155:{int(chain_id)}/{namespace}:{_normalize_node_key(raw_key)}"


def token_node_id(chain_id: int, address: str) -> str:
    return node_id(chain_id, "erc20", address)


@dataclass
class Price:
    value: Optional[float] = None
    timestamp: Optional[int] = None
    symbol: Optional[str] = None
    confidence: Optional[float] = None


def _is_blank(value: Any) -> bool:
    return value in (None, [], {}, "")


@dataclass
class Node:
    id: str
    address: Optional[str]
    chainId: int
    kind: str = "token"
    label: Optional[str] = None
    symbol: Optional[str] = None
    decimals: Optional[int] = None
    role: str = "plain"
    protocol: Optional[str] = None
    project: Optional[str] = None
    tvl: Optional[float] = None
    apy_base: Optional[float] = None
    apy_reward: Optional[float] = None
    price: Optional[Price] = None
    source: str = "enso"
    extra: Dict[str, Any] = field(default_factory=dict)

    def merge_from(self, other: "Node") -> None:
        for model_field in fields(self):
            key = model_field.name
            if key in ("id", "address", "chainId", "kind"):
                continue
            current = getattr(self, key)
            incoming = getattr(other, key)
            if _is_blank(current) and not _is_blank(incoming):
                setattr(self, key, incoming)


@dataclass
class Edge:
    src: str
    dst: str
    type: str
    notes: Optional[str] = None
    source: str = "enso"

    @property
    def key(self) -> Tuple[str, str, str]:
        return (self.src, self.type, self.dst)


@dataclass
class Graph:
    root: str
    nodes: Dict[str, Node] = field(default_factory=dict)
    edges: List[Edge] = field(default_factory=list)
    meta: Dict[str, Any] = field(default_factory=dict)
    _edge_set: Set[Tuple[str, str, str]] = field(default_factory=set, repr=False)

    def add_node(self, node: Node) -> None:
        if node.id in self.nodes:
            self.nodes[node.id].merge_from(node)
        else:
            self.nodes[node.id] = node

    def add_edge(self, edge: Edge) -> None:
        if edge.key not in self._edge_set:
            self.edges.append(edge)
            self._edge_set.add(edge.key)

    def to_dict(self) -> Dict[str, Any]:
        def _node_to_dict(node: Node) -> Dict[str, Any]:
            data = asdict(node)
            if node.price and isinstance(node.price, Price):
                data["price"] = asdict(node.price)
            return data

        return {
            "root": self.root,
            "nodes": [_node_to_dict(node) for node in self.nodes.values()],
            "edges": [asdict(edge) for edge in self.edges],
            "meta": self.meta,
        }

    def to_json(self, compact: bool = False) -> str:
        if compact:
            return json.dumps(self.to_dict(), separators=(",", ":"), sort_keys=False)
        return json.dumps(self.to_dict(), indent=2, sort_keys=False)

    def to_dot(self, min_tvl: float = 0.0) -> str:
        _VENUE_KINDS = {"lending_market", "dex_pool"}
        if min_tvl > 0:
            skip_ids = {
                n.id for n in self.nodes.values()
                if n.kind in _VENUE_KINDS and (n.tvl is None or n.tvl < min_tvl)
            }
        else:
            skip_ids = set()

        role_color = {
            "plain": "#C3B091",
            "wrapper": "#C3B091",
            "lp": "#F8C0D8",
            "vault_share": "#FFF3B0",
            "staked": "#90EE90",
            "stripped": "#DDA0DD",
            "collateral": "#FFB366",
            "other": "#D0D0D0",
        }
        kind_color = {
            "token": None,
            "lending_market": "#FEEA9D",
            "dex_pool": "#E7A29D",
            "venue": "#F4EEEA",
        }
        # Protocol-specific overrides (checked before kind/role)
        protocol_color = {
            "pendle": "#B8E6B8",       # light green — PT/YT/SY
            "morpho": "#FEEA9D",       # pale yellow — lending markets
            "aave-v3": "#FDE68A",      # deeper yellow — Aave
            "euler": "#E8A317",        # dark gold — Euler vaults
            "uniswap-v3": "#E7A29D",   # salmon — dex pools
        }
        lines = [
            "digraph G {",
            "  rankdir=LR;",
            '  node [shape=box, style="rounded,filled", fontname="Helvetica"];',
        ]
        for node in self.nodes.values():
            if node.id in skip_ids:
                continue
            color = (
                protocol_color.get(node.protocol or "")
                or protocol_color.get((node.project or "").lower())
                or kind_color.get(node.kind)
                or role_color.get(node.role, "#D0D0D0")
            )
            label = node.label or node.symbol or node.address or node.id
            sub = []
            if node.kind and node.kind != "token":
                sub.append(node.kind)
            if node.symbol and node.symbol != label:
                sub.append(node.symbol)
            if node.role and node.role != "plain":
                sub.append(node.role)
            if node.protocol:
                sub.append(node.protocol)
            if sub:
                label = f"{label}\\n({', '.join(sub)})"
            penwidth = ', penwidth=3' if node.id == self.root else ''
            lines.append(f'  "{node.id}" [label="{label}", fillcolor="{color}"{penwidth}];')
        for edge in self.edges:
            if edge.src in skip_ids or edge.dst in skip_ids:
                continue
            lines.append(f'  "{edge.src}" -> "{edge.dst}" [label="{edge.type}"];')
        lines.append("}")
        return "\n".join(lines)


_LST_SYMBOLS = {"stETH", "wstETH", "rETH", "eETH", "weETH", "cbETH", "mETH", "sfrxETH", "BETH"}


def infer_role_from_enso(token_payload: Dict[str, Any]) -> str:
    underlyings = token_payload.get("underlyingTokens") or []
    symbol = (token_payload.get("symbol") or "").strip()
    slug = (token_payload.get("protocolSlug") or "").lower()

    # Pendle principal/yield tokens
    if "pendle" in slug and (symbol.startswith("PT-") or symbol.startswith("YT-")):
        return "stripped"

    # Liquid staking derivatives
    if symbol in _LST_SYMBOLS:
        return "staked"

    # Count-based fallback
    if len(underlyings) >= 2:
        return "lp"
    if len(underlyings) == 1:
        return "wrapper"
    return "plain"


def edge_type_for_source_role(role: str) -> str:
    # This mapper is structural-only. Venue verbs such as PLEDGE or SWAP
    # belong on token -> venue edges emitted by protocol adapters.
    if role == "lp":
        return "CONTAINS"
    if role == "vault_share":
        return "VAULT"
    if role == "staked":
        return "STAKE"
    if role == "stripped":
        return "STRIP"
    return "WRAPS"


_ENSO_NODE_OMIT_KEYS = {
    "address",
    "chainId",
    "name",
    "symbol",
    "decimals",
    "type",
    "project",
    "protocolSlug",
    "primaryAddress",
    "apy",
    "apyBase",
    "apyReward",
    "tvl",
    "underlyingTokens",
    "logosUri",
    "price",
    "sources",
    "underlyingResolved",
}


def node_from_enso_payload(payload: Dict[str, Any]) -> Node:
    address = normalize_addr(payload.get("address")) or ""
    chain_id = int(payload.get("chainId") or payload.get("chain_id") or 1)
    price_payload = payload.get("price") or {}
    return Node(
        id=token_node_id(chain_id, address),
        address=address,
        chainId=chain_id,
        kind="token",
        label=payload.get("name"),
        symbol=payload.get("symbol"),
        decimals=payload.get("decimals"),
        role=infer_role_from_enso(payload),
        protocol=payload.get("protocolSlug"),
        project=payload.get("project"),
        tvl=payload.get("tvl"),
        apy_base=payload.get("apyBase"),
        apy_reward=payload.get("apyReward"),
        price=Price(
            value=price_payload.get("value"),
            timestamp=price_payload.get("timestamp"),
            symbol=price_payload.get("symbol"),
            confidence=price_payload.get("confidence"),
        )
        if payload.get("price") is not None
        else None,
        source="enso",
        extra={key: value for key, value in payload.items() if key not in _ENSO_NODE_OMIT_KEYS},
    )


--- ./core/NEIGH_README.md ---
# Neighborhood Graph (`neigh`)

Builds a directed graph around an ERC-20 token showing how it relates to
wrappers, LPs, vaults, lending markets, and DEX pools.

## How it works

1. **Double BFS** from a root token address via Enso:
   - *Downstream* — underlyings (what the token is built on)
   - *Upstream* — dependents (what is built on the token)
2. **Venue adapters** run against **upstream-cone tokens only** (the root
   plus its dependents). Downstream underlyings are not checked for venues,
   since the goal is to find where the token and its derivatives can be
   deployed, not where its building blocks trade.
   - `--with-morpho` — Morpho Blue markets (LEND / PLEDGE)
   - `--with-aave` — Aave v3 reserves (LEND / PLEDGE)
   - `--with-euler` — Euler markets (LEND / PLEDGE via `canUseAsCollateral`)
   - `--with-univ3` — Uniswap v3 pools (SWAP)

## Node kinds

| Kind             | What it represents                |
|------------------|-----------------------------------|
| `token`          | ERC-20 token                      |
| `lending_market` | A supply/borrow position on a venue |
| `dex_pool`       | A liquidity pool                  |

## Edge types

| Edge      | Meaning                              | Example                                  |
|-----------|--------------------------------------|------------------------------------------|
| `WRAPS`   | single-underlying wrapper            | wstETH wraps stETH                       |
| `CONTAINS`| LP or multi-token underlying         | reUSD/USDC Curve LP contains reUSD       |
| `VAULT`   | ERC-4626 vault share                 | yvUSDC vault holds USDC                  |
| `STAKE`   | liquid staking derivative            | stETH stakes ETH                         |
| `STRIP`   | Pendle PT / YT                       | PT-reUSD-25JUN2026 strips SY-reUSD      |
| `LEND`    | token can be supplied to a market    | USDC lends to USDC/stcUSD @ Morpho      |
| `PLEDGE`  | token is collateral in a market      | WETH pledges to WETH @ Euler            |
| `SWAP`    | token trades in a pool               | USDC swaps in USDC/WETH @ Uniswap v3   |

## Usage

```bash
# JSON to stdout
uv run python core/neigh.py 0x... --with-morpho --with-euler

# JSON + DOT files, filter dust markets from DOT
uv run python core/neigh.py 0x... \
  --with-morpho --with-aave --with-euler --with-univ3 \
  --out graphs/token.json --dot graphs/token.dot --min-tvl 1000

# Render DOT to PNG
dot -Tpng graphs/token.dot -o graphs/token.png
```

## Key flags

| Flag            | Default | Effect                                         |
|-----------------|---------|-------------------------------------------------|
| `--chain-id`    | 1       | Chain (Ethereum mainnet)                        |
| `--downstream`  | 4       | BFS depth for underlyings                       |
| `--upstream`    | 4       | BFS depth for dependents                        |
| `--no-onchain`  | off     | Skip ERC-4626 `asset()` probes                  |
| `--min-tvl`     | 0       | Hide venue nodes below this TVL in DOT output   |
| `--out`         | stdout  | Write JSON graph to file                        |
| `--dot`         | —       | Write Graphviz DOT to file                      |

## Outputs

- **JSON** — full graph with all nodes, edges, prices, APYs, TVLs, and
  extras. Always complete regardless of `--min-tvl`.
- **DOT** — visual graph for Graphviz. Venue nodes below `--min-tvl` are
  hidden (along with their edges) to reduce clutter.

## Files

| File                       | Role                              |
|----------------------------|-----------------------------------|
| `neigh.py`                 | CLI entry point                   |
| `neigh_bfs.py`             | Double BFS builder                |
| `neigh_helpers.py`         | Watcher loaders, token utilities  |
| `neighborhood_common.py`   | Graph/Node/Edge types, DOT/JSON   |
| `neigh_adapter_morpho.py`  | Morpho venue adapter              |
| `neigh_adapter_aave.py`    | Aave venue adapter                |
| `neigh_adapter_euler.py`   | Euler venue adapter               |
| `neigh_adapter_univ3.py`   | Uniswap v3 venue adapter          |


--- ./merged_neigh_plan.md ---
# Neighborhood Graph Plan

## Completed work

### Phase 1: Stabilize (done)

Fixed `_is_blank(0)`, made ERC-4626 probing chain-aware, renamed `ACCEPTS` to
`VAULT`, added logging, added PT/LST structural heuristics in
`infer_role_from_enso()`, cleaned stale diagnostics. Tests in
`tests/test_neigh.py` and `tests/test_neighborhood_common.py`.

### Phase 2: Dark venues + module split (done)

Split monolithic `neigh.py` into:

| Module | Role |
|--------|------|
| `core/neigh.py` | Thin CLI wrapper |
| `core/neigh_bfs.py` | Double-BFS traversal, EnsoCache, venue adapter orchestration |
| `core/neigh_helpers.py` | Shared adapter infra: watcher loading, token filtering, Pendle expiry |
| `core/neigh_adapter_aave.py` | Aave v3 `lending_market` nodes + LEND/PLEDGE edges |
| `core/neigh_adapter_morpho.py` | Morpho `lending_market` nodes + LEND/PLEDGE edges |
| `core/neigh_adapter_univ3.py` | Uniswap v3 `dex_pool` nodes + SWAP edges |
| `core/neighborhood_common.py` | Graph model (Node, Edge, Graph), role inference, serialization |

Edge types: WRAPS, CONTAINS, VAULT, STAKE, STRIP (structural) + LEND, PLEDGE,
SWAP (venue). CLI flags: `--with-morpho`, `--with-aave`, `--with-univ3`.

---

## Next work

### Phase A: Euler adapter

Add `core/neigh_adapter_euler.py` following the established adapter pattern.

**Helper:** Add `fetch_euler_markets_for_chain(chain_id)` in
`core/neigh_helpers.py`. Returns `[]` for non-Ethereum chains (Euler is chain 1
only). Calls `module.fetch_markets(None)` — the public watcher API, not the
lower-level `fetch_markets_from_subgraph()` — to preserve fallback/resilience
behavior consistent with the Aave/Morpho helpers.

**Watcher:** Load via `_load_watch_module("eulerWatch.py",
"kildef_watchers.eulerWatch")`.

**Graph model:**

- Node kind: `lending_market`, protocol: `euler`
- Node ID: `node_id(chain_id, "lending_market", f"euler:{market['id']}")` —
  uses the subgraph `id` field (the market contract address)
- Edge types: `LEND` (supply side); `PLEDGE` if collateral-eligible — the
  Messari subgraph exposes `canUseAsCollateral` per market (now fetched in
  both `EulerMarkets` and `EulerMarketsLite` queries and threaded through
  `to_rows()` as `row["canUseAsCollateral"]`). The adapter should gate PLEDGE
  on this field, analogous to Aave's `canBeCollateral` check at
  `neigh_adapter_aave.py:101`.

**CLI:** `--with-euler`

**Tests** (`tests/test_neigh_adapter_euler.py`):

- Happy path: market nodes created with LEND + PLEDGE edges (when
  `canUseAsCollateral` is true)
- Non-Ethereum chain: no-op (returns empty)
- Root Enso failure: venue attachment still works from stub node
- Watcher/subgraph failure: logged warning, no crash

**Files:**

- `core/neigh_adapter_euler.py` (new, ~100 lines)
- `core/neigh_helpers.py` (add `fetch_euler_markets_for_chain`)
- `core/neigh_bfs.py` (add `with_euler` param + adapter call)
- `core/neigh.py` (add `--with-euler` flag)
- `tests/test_neigh_adapter_euler.py` (new)

### Phase B: Pendle market metadata enrichment

PT/YT/SY tokens already appear as graph nodes via Enso (role=stripped). The
existence of a Pendle market is implicit from the PT node — adding venue nodes
would clutter the graph. Instead, enrich existing PT nodes with market-level
data.

**Unify fetch paths:** Currently `fetch_expired_pendle_addresses()` in
`neigh_helpers.py` fetches all markets from the Pendle v2 API but only extracts
expiry sets. `watchers/pendleWatch.py::fetch_markets()` fetches only active
markets. These are different data sources. Refactor: introduce a shared
`_fetch_all_pendle_markets(chain_id)` in `neigh_helpers.py` that caches the
full market list. Both `fetch_expired_pendle_addresses()` and the enrichment
adapter consume it. This avoids double-fetching and ensures enrichment covers
all markets (not just active ones).

**Enrichment approach:** After BFS completes, match PT nodes to their Pendle
market and inject market metadata into the PT node's fields/extra.

**Important:** Do NOT overload `apy_base` with Pendle implied APR. In the
current graph, `apy_base` means ongoing supply/base yield (Enso, Aave, Morpho).
Pendle's `impliedApr` is a discount-to-maturity concept — fundamentally
different. Keep Pendle-specific data in `extra`:

- `tvl` ← market TVL (if not already set — this one is safe to use)
- `extra.implied_apr` ← Pendle implied APR
- `extra.base_apr` ← underlying base APR
- `extra.reward_apr` ← reward APR
- `extra.expiry` ← market expiry ISO timestamp
- `extra.pendle_market_address` ← market contract address
- `extra.pt_discount` ← discount to par (if available)

No new node kind, no new edge type.

