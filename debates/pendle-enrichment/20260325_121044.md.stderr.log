# -*- coding: utf-8 -*-
"""
Neighborhood builder CLI — thin wrapper around neigh_bfs.
"""

from __future__ import annotations

import os
import argparse
from typing import List, Optional

from neigh_bfs import build_neighborhood_double_bfs


def _main(argv: Optional[List[str]] = None) -> int:
    p = argparse.ArgumentParser(description="Builds token neighborhood via double BFS (using Enso).")
    p.add_argument("address", help="ERC-20 address (0x...)")
    p.add_argument("--chain-id", type=int, default=1)
    p.add_argument("--downstream", type=int, default=4, help="Depth N for underlyings cone (U direction)")
    p.add_argument("--upstream", type=int, default=4, help="Depth n for dependents cone (U* direction)")
    p.add_argument("--no-onchain", action="store_true", help="Disable ERC-4626 asset() probe")
    p.add_argument("--with-morpho", action="store_true", help="Attach Morpho market nodes and venue edges")
    p.add_argument("--with-aave", action="store_true", help="Attach Aave reserve nodes and venue edges")
    p.add_argument("--with-euler", action="store_true", help="Attach Euler market nodes and venue edges")
    p.add_argument("--with-univ3", action="store_true", help="Attach Uniswap v3 pool nodes and SWAP edges")
    p.add_argument("--out", type=str, default=None, help="Write JSON graph to this path")
    p.add_argument("--dot", type=str, default=None, help="Write Graphviz DOT to this path")
    p.add_argument("--min-tvl", type=float, default=0.0, help="Hide venue nodes (markets/pools) below this TVL in DOT output")

    args = p.parse_args(argv)

    g = build_neighborhood_double_bfs(
        token_address=args.address,
        chain_id=args.chain_id,
        downstream_depth=max(0, int(args.downstream)),
        upstream_depth=max(0, int(args.upstream)),
        onchain_probe=not args.no_onchain,
        with_morpho=args.with_morpho,
        with_aave=args.with_aave,
        with_euler=args.with_euler,
        with_univ3=args.with_univ3,
    )

    payload = g.to_json()
    if args.out:
        os.makedirs(os.path.dirname(os.path.abspath(args.out)), exist_ok=True)
        with open(args.out, "w", encoding="utf-8") as fh:
            fh.write(payload + "\n")
    else:
        print(payload)

    if args.dot:
        dot = g.to_dot(min_tvl=args.min_tvl)
        os.makedirs(os.path.dirname(os.path.abspath(args.dot)), exist_ok=True)
        with open(args.dot, "w", encoding="utf-8") as fh:
            fh.write(dot + "\n")

    return 0

if __name__ == "__main__":
    raise SystemExit(_main())


