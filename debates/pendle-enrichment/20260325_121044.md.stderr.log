# -*- coding: utf-8 -*-
"""Euler venue adapter for neighborhood graph."""

from __future__ import annotations

from typing import Optional, Set

from neighborhood_common import Edge, Graph, Node, node_id, normalize_addr
from neigh_helpers import (
    _enrich_token_node,
    _token_nodes_by_chain,
    fetch_euler_markets_for_chain,
)
from utils import get_logger, safe_float

log = get_logger("neigh")


def _attach_euler_market_nodes(graph: Graph, eligible_ids: Optional[Set[str]] = None) -> None:
    token_nodes_by_chain = _token_nodes_by_chain(graph, eligible_ids=eligible_ids)
    if not token_nodes_by_chain:
        return

    for chain_id, token_nodes in token_nodes_by_chain.items():
        try:
            rows = fetch_euler_markets_for_chain(chain_id)
        except Exception as exc:
            log.warning("Euler market fetch failed for chain %s: %s", chain_id, exc)
            continue

        for row in rows:
            asset_addr = normalize_addr(row.get("asset_addr"))
            if not asset_addr:
                continue

            token_node = token_nodes.get(asset_addr)
            if token_node is None:
                continue

            asset_symbol = row.get("asset") or row.get("asset_symbol") or token_node.symbol or "token"
            _enrich_token_node(token_node, symbol=asset_symbol, label=asset_symbol)

            market_addr = normalize_addr(row.get("market_addr"))
            market_node_id = node_id(chain_id, "lending_market", f"euler:{market_addr or asset_addr}")

            market_node = Node(
                id=market_node_id,
                address=market_addr,
                chainId=chain_id,
                kind="lending_market",
                label=f"{asset_symbol} @ Euler",
                symbol=asset_symbol,
                role="other",
                protocol="euler",
                project="Euler",
                tvl=safe_float(row.get("supplyUSD"), default=None),
                apy_base=safe_float(row.get("supplyAPY"), default=None),
                source="eulerWatch",
                extra={
                    "market_address": market_addr,
                    "asset_address": asset_addr,
                    "can_use_as_collateral": bool(row.get("canUseAsCollateral")),
                    "liquidity_usd": safe_float(row.get("liquidityUSD"), default=None),
                    "borrow_usd": safe_float(row.get("borrowUSD"), default=None),
                    "borrow_apy": safe_float(row.get("borrowAPY"), default=None),
                    "utilization": safe_float(row.get("util"), default=None),
                    "net_supply_apy": safe_float(row.get("netSupplyAPY"), default=None),
                },
            )
            graph.add_node(market_node)
            graph.add_edge(Edge(
                src=token_node.id,
                dst=market_node.id,
                type="LEND",
                notes="euler market",
                source="eulerWatch",
            ))

            if row.get("canUseAsCollateral"):
                graph.add_edge(Edge(
                    src=token_node.id,
                    dst=market_node.id,
                    type="PLEDGE",
                    notes="euler collateral",
                    source="eulerWatch",
                ))


